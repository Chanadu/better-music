<button
  id="theme-toggle"
  class="flex cursor-pointer items-center justify-center rounded-lg border border-border bg-surface px-3 py-2 transition-colors hover:bg-surface-raised"
>
  <span id="theme-icon" class="text-lg">🌙</span>
</button>

<script>
  const toggle = document.getElementById('theme-toggle') as HTMLButtonElement | null;
  const icon = document.getElementById('theme-icon') as HTMLSpanElement | null;

  function syncToggle(): void {
    const isDark = document.documentElement.classList.contains('dark');
    if (icon) icon.textContent = isDark ? '☀️' : '🌙';
  }

  function toggleTheme(): void {
    window.toggleTheme();
    syncToggle();
  }

  toggle?.addEventListener('click', toggleTheme);
  syncToggle();
</script>
