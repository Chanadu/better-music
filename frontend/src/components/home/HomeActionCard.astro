---
interface Props {
	title: string;
	description: string;
	href?: string;
	buttonLabel: string;
	buttonId?: string;
	buttonVariant?: 'primary' | 'secondary';
	cardClassName?: string;
}

const {
	title,
	description,
	href,
	buttonLabel,
	buttonId,
	buttonVariant = 'primary',
	cardClassName = '',
} = Astro.props as Props;

const buttonClass =
	buttonVariant === 'secondary'
		? 'bg-secondary text-white shadow-sm shadow-secondary/20 hover:bg-secondary-hover hover:shadow-md'
		: 'bg-primary text-primary-fg shadow-sm shadow-primary/20 hover:bg-primary-hover hover:shadow-md';
const headingHoverClass = buttonVariant === 'secondary' ? 'group-hover:text-secondary' : 'group-hover:text-primary';
const iconClass = buttonVariant === 'secondary' ? 'bg-secondary/10 text-secondary' : 'bg-primary/10 text-primary';
---

<div
	class:list={[
		'group relative overflow-hidden rounded-3xl border border-border/60 bg-surface-raised p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-linear-to-br hover:from-surface-raised hover:to-primary/5 hover:shadow-md',
		cardClassName,
	]}
>
	<div class:list={['mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl transition-transform duration-300 group-hover:scale-110', iconClass]}>
		<slot name="icon" />
	</div>
	<h3 class:list={['text-xl font-bold tracking-tight text-text', headingHoverClass]}>{title}</h3>
	<p class="mt-1 text-sm text-text-muted">{description}</p>

	{href ? (
		<a href={href} class:list={['mt-6 flex w-full items-center justify-center gap-2 rounded-xl px-4 py-3 text-sm font-semibold transition-all active:scale-95', buttonClass]}>
			{buttonLabel}
		</a>
	) : (
		<button id={buttonId} type="button" class:list={['mt-6 flex w-full cursor-pointer items-center justify-center gap-2 rounded-xl px-4 py-3 text-sm font-semibold transition-all active:scale-95', buttonClass]}>
			{buttonLabel}
		</button>
	)}
</div>
