---
import EmailInput from './EmailInput.astro';
import PasswordInput from './PasswordInput.astro';
---

<form data-auth-form data-auth-action='login' data-success-path='/'>
	<fieldset class='fieldset flex flex-col gap-4'>
		<label class='label'>Email</label>
		<EmailInput />

		<label class='label'>Password</label>
		<PasswordInput />

		<p class='text-error hidden text-center text-sm' data-auth-error></p>
		<button type='submit' class='btn btn-primary btn-disabled mx-auto mt-4 w-min' disabled>Login</button>
		<div class='text-primary hidden justify-center' aria-live='polite' data-auth-loading>
			<span class='loading loading-spinner loading-md' aria-label='Logging in'></span>
		</div>
	</fieldset>
</form>

<script>
	import { setupAuthForms } from '../../scripts/auth-form';

	setupAuthForms();
</script>
