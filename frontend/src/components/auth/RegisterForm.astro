---
import AuthInputField from './AuthInputField.astro';
import { BUTTON_PRIMARY_CLASS } from '../../lib/button-styles';
---

<form class='w-full space-y-5'>
	<AuthInputField
		id='email'
		name='email'
		label='Email Address'
		type='email'
		placeholder='you@example.com'
		required={true}
	/>

	<AuthInputField
		id='password'
		name='password'
		label='Password'
		type='password'
		placeholder='••••••••'
		required={true}
	/>

	<AuthInputField
		id='confirm-password'
		name='confirm-password'
		label='Confirm Password'
		type='password'
		placeholder='••••••••'
		required={true}
	/>

	<!-- Error Message -->
	<div id='error-message' class='bg-error hidden rounded-lg p-3 text-sm text-white shadow-md'></div>

	<button
		type='submit'
		class:list={[BUTTON_PRIMARY_CLASS, 'w-full']}
	>
		Create Account
	</button>

		<div class='border-border border-t pt-5'>
			<p class='text-text-muted text-center text-sm'>
			Already have an account? <a href='/' class='text-primary font-semibold transition-opacity hover:opacity-80 active:opacity-65'>
				Sign in
			</a>
		</p>
	</div>
</form>

<script>
	import { APP_HOME_PATH, apiFetch, getErrorMessage, storeAuthTokens } from '../../lib/api';
	import { setupAuthForm } from '../../lib/auth-form';

	const form = document.querySelector('form');
	const errorMessage = document.getElementById('error-message');
	const authForm = setupAuthForm(form, errorMessage, 'Create Account', ['email', 'password', 'confirm-password']);

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		if (!authForm) return;

		const formData = new FormData(form);
		const email = formData.get('email');
		const password = formData.get('password');
		const confirmPassword = formData.get('confirm-password');

		if (password !== confirmPassword) {
			authForm.setFailureState('Passwords do not match.', 'Create Account');
			return;
		}

		authForm.setSubmittingState('Creating account...');

		try {
			const response = await apiFetch(
				'/api/auth/register',
				{
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({ email, password }),
				},
				{ auth: false, retryOnUnauthorized: false },
			);

			if (!response.ok) {
				const errorText = await getErrorMessage(response, 'Registration failed');
				authForm.setFailureState(errorText);
				return;
			}

			const data = await response.json();
			storeAuthTokens(data);
			window.location.assign(APP_HOME_PATH);
		} catch (err) {
			authForm.setFailureState('An error occurred. Please try again.');
			console.error(err);
		}
	});
</script>
