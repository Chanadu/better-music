---
import AuthInputField from './AuthInputField.astro';
---

<form class="w-full space-y-5">
  <AuthInputField id="email" name="email" label="Email Address" type="email" placeholder="you@example.com" required={true} />

  <AuthInputField id="password" name="password" label="Password" type="password" placeholder="••••••••" required={true} />

  <AuthInputField id="confirm-password" name="confirm-password" label="Confirm Password" type="password" placeholder="••••••••" required={true} />

  <!-- Error Message -->
  <div id="error-message" class="hidden rounded-lg bg-error p-3 text-sm text-white shadow-md">
  </div>

  <button
    type="submit"
    class="w-full cursor-pointer rounded-xl bg-primary px-4 py-3 text-base font-semibold text-primary-fg shadow-md shadow-primary/20 transition-all duration-300 hover:-translate-y-0.5 hover:bg-primary-hover hover:shadow-lg hover:shadow-primary/30 focus:ring-4 focus:ring-primary/20 active:scale-95 disabled:cursor-not-allowed disabled:opacity-50 disabled:hover:translate-y-0 disabled:hover:shadow-md"
  >
    Create Account
  </button>

  <div class="border-t border-border pt-5">
    <p class="text-center text-sm text-text-muted">
      Already have an account? <a href="/login" class="font-semibold text-primary transition-opacity hover:opacity-80">
        Sign in
      </a>
    </p>
  </div>
</form>

<script>
  import { navigate } from 'astro:transitions/client';
import { apiFetch, getErrorMessage, storeAuthTokens } from '../../lib/api';
import { setupAuthForm } from '../../lib/auth-form';

  const form = document.querySelector('form');
  const errorMessage = document.getElementById('error-message');
  const authForm = setupAuthForm(form, errorMessage, 'Create Account', ['email', 'password', 'confirm-password']);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!authForm) return;

    const formData = new FormData(form);
    const email = formData.get('email');
    const password = formData.get('password');
    const confirmPassword = formData.get('confirm-password');

    if (password !== confirmPassword) {
      authForm.setFailureState('Passwords do not match.', 'Create Account');
      return;
    }

    authForm.setSubmittingState('Creating account...');

    try {
		  const response = await apiFetch('/api/auth/register', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ email, password }),
      }, { auth: false, retryOnUnauthorized: false });

      if (!response.ok) {
			const errorText = await getErrorMessage(response, 'Registration failed');
        authForm.setFailureState(errorText);
        return;
      }

      const data = await response.json();
      storeAuthTokens(data);
			void navigate('/');
    } catch (err) {
      authForm.setFailureState('An error occurred. Please try again.');
      console.error(err);
    }
  });
</script>
