---
import FloatingInput from '../ui/FloatingInput.astro';

interface Props {
	id: string;
	name: string;
	label: string;
	type?: 'text' | 'email' | 'password' | 'search' | 'url' | 'tel' | 'number';
	placeholder?: string;
	required?: boolean;
}

const { id, name, label, type = 'text', required = false } = Astro.props;
---

<FloatingInput id={id} name={name} label={label} type={type} required={required} />
