---
interface Props {
	id: string;
	name: string;
	label: string;
	type?: 'text' | 'email' | 'password' | 'search' | 'url' | 'tel' | 'number';
	placeholder?: string;
	required?: boolean;
}

const { id, name, label, type = 'text', placeholder = '', required = false } = Astro.props;
---

<div>
	<label for={id} class="block text-sm font-semibold" style="color: var(--text);">
		{label}
	</label>
	<input
		type={type}
		id={id}
		name={name}
		required={required}
		class="mt-2 w-full rounded-lg border-2 px-4 py-3 transition-colors focus:outline-none focus:ring-2"
		style="border-color: var(--border); background: var(--surface-raised); color: var(--text); --tw-ring-color: hsla(285, 100%, 58%, 0.3);"
		placeholder={placeholder}
	/>
</div>
