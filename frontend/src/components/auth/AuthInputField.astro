---
interface Props {
	id: string;
	name: string;
	label: string;
	type?: 'text' | 'email' | 'password' | 'search' | 'url' | 'tel' | 'number';
	placeholder?: string;
	required?: boolean;
}

const { id, name, label, type = 'text', placeholder = '', required = false } = Astro.props;
---

<div class="relative">
	<input
		type={type}
		id={id}
		name={name}
		required={required}
		class="peer w-full rounded-xl border border-border/60 bg-surface-raised/50 px-4 pb-2 pt-6 text-base text-text transition-all duration-200 focus:border-primary/60 focus:bg-surface-raised focus:outline-none focus:ring-4 focus:ring-primary/10"
		placeholder=" "
	/>
	<label for={id} class="pointer-events-none absolute left-4 top-2 text-xs font-semibold text-text-muted transition-all peer-placeholder-shown:top-1/2 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:text-base peer-placeholder-shown:font-normal peer-focus:top-2 peer-focus:translate-y-0 peer-focus:text-xs peer-focus:font-semibold">
		{label}
	</label>
</div>
