---
interface Props {
	id: string;
	name: string;
	label: string;
	type?: 'text' | 'email' | 'password' | 'search' | 'url' | 'tel' | 'number';
	placeholder?: string;
	required?: boolean;
}

const { id, name, label, type = 'text', placeholder = '', required = false } = Astro.props;
---

<div>
	<label for={id} class="block text-sm font-semibold text-text">
		{label}
	</label>
	<input
		type={type}
		id={id}
		name={name}
		required={required}
		class="mt-2 w-full rounded-xl border border-border/60 bg-surface-raised/50 px-4 py-4 text-base text-text transition-all duration-200 focus:border-primary/60 focus:bg-surface-raised focus:outline-none focus:ring-4 focus:ring-primary/10"
		placeholder={placeholder}
	/>
</div>
