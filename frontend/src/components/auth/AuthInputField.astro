---
interface Props {
	id: string;
	name: string;
	label: string;
	type?: 'text' | 'email' | 'password' | 'search' | 'url' | 'tel' | 'number';
	placeholder?: string;
	required?: boolean;
}

const { id, name, label, type = 'text', placeholder = '', required = false } = Astro.props;
---

<div>
	<label for={id} class="block text-sm font-semibold text-text">
		{label}
	</label>
	<input
		type={type}
		id={id}
		name={name}
		required={required}
		class="mt-2 w-full rounded-lg border-2 border-border bg-surface-raised px-4 py-3 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
		placeholder={placeholder}
	/>
</div>
