---
import Panel from '../ui/Panel.astro';
---

<main class="flex min-h-screen flex-col items-center justify-center px-4 py-8 sm:px-6 sm:py-12 md:px-8" style="background: linear-gradient(to bottom right, var(--bg), var(--surface-raised));">
	<div class="w-full max-w-sm space-y-6">
		<div class="space-y-3 text-center">
			<div class="flex justify-center">
				<div class="flex h-12 w-12 items-center justify-center rounded-lg sm:h-14 sm:w-14" style="background: var(--primary); color: var(--primary-fg);">
					<svg viewBox="0 0 24 24" class="h-7 w-7 sm:h-8 sm:w-8" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
						<path d="M9 18a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Zm11-2a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Z"></path>
						<path d="M9 18V6l11-2v12"></path>
						<path d="M9 10l11-2"></path>
					</svg>
				</div>
			</div>
			<div>
				<h1 class="text-3xl font-bold sm:text-4xl" style="color: var(--text);">
					Better Music
				</h1>
			</div>
		</div>

		<Panel>
			<slot />
		</Panel>
	</div>
</main>
