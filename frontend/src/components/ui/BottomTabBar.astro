---
interface Props {
	current: 'home' | 'albums' | 'artists';
}

const { current } = Astro.props;

const baseClass =
	'flex min-h-12 flex-col items-center justify-center rounded-xl px-2 py-2 text-[11px] font-semibold leading-tight transition-colors';
const activeClass = 'text-primary';
const inactiveClass = 'text-text-muted hover:text-text';
---

<nav
	class='fixed right-4 left-4 z-40 rounded-2xl border border-border bg-surface-raised/85 shadow-lg backdrop-blur-md dark:shadow-black/20'
	style='bottom: calc(env(safe-area-inset-bottom, 0px) + 1rem);'
>
	<div class='grid w-full grid-cols-4 px-2 pb-2 sm:px-4'>
		<div class='border-r border-border'>
			<a href='/' class={`${baseClass} ${current === 'home' ? activeClass : inactiveClass}`}>
				<svg viewBox='0 0 24 24' class='h-8 w-8' fill='none' stroke='currentColor' stroke-width='1.8' aria-hidden='true'>
					<path d='M3 11.5 12 4l9 7.5'></path>
					<path d='M5.5 10.5V20h13V10.5'></path>
					<path d='M10 20v-5h4v5'></path>
				</svg>
				<span class='mt-1 text-sm'>Home</span>
			</a>
		</div>
		<div class='border-r border-border'>
			<a href='/albums' class={`${baseClass} ${current === 'albums' ? activeClass : inactiveClass}`}>
				<svg viewBox='0 0 24 24' class='h-8 w-8' fill='none' stroke='currentColor' stroke-width='1.8' aria-hidden='true'>
					<circle cx='12' cy='12' r='8'></circle>
					<circle cx='12' cy='12' r='2'></circle>
				</svg>
				<span class='mt-1 text-sm'>Albums</span>
			</a>
		</div>
		<div class='border-r border-border'>
			<a href='/artists' class={`${baseClass} ${current === 'artists' ? activeClass : inactiveClass}`}>
				<svg viewBox='0 0 24 24' class='h-8 w-8' fill='none' stroke='currentColor' stroke-width='1.8' aria-hidden='true'>
					<circle cx='12' cy='7' r='4'></circle>
					<path d='M4 21c0-4.2 3.6-7 8-7s8 2.8 8 7'></path>
				</svg>
				<span class='mt-1 text-sm'>Artists</span>
			</a>
		</div>
		<div>
			<button
				type='button'
				id='open-create-tab'
				class={`${baseClass} ${inactiveClass} w-full`}
				aria-label='Open create menu'
			>
				<svg viewBox='0 0 24 24' class='h-8 w-8' fill='none' stroke='currentColor' stroke-width='1.8' aria-hidden='true'>
					<path d='M12 5v14'></path>
					<path d='M5 12h14'></path>
				</svg>
				<span class='mt-1 text-sm'>Create</span>
			</button>
		</div>
	</div>
</nav>

<script>
	const windowWithFlag = window as Window & { __createTabBound?: boolean };
	if (!windowWithFlag.__createTabBound) {
		windowWithFlag.__createTabBound = true;
		document.addEventListener('click', (event) => {
			const target = event.target as Element | null;
			const button = target?.closest('#open-create-tab') as HTMLButtonElement | null;
			if (!button) return;
			event.preventDefault();
			window.dispatchEvent(new CustomEvent('open-create-menu'));
		});
	}
</script>
