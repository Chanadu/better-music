---
import {
	BUTTON_COMPACT_ICON_SECONDARY_CLASS,
	BUTTON_SECONDARY_CLASS,
} from '../../lib/button-styles';

interface Props {
	buttonId: string;
	label?: string;
	className?: string;
	iconOnly?: boolean;
}

const {
	buttonId,
	label = 'Refresh from Spotify',
	className = '',
	iconOnly = false,
} = Astro.props as Props;
---

<button
	type='button'
	id={buttonId}
	aria-label={label}
	title={label}
	data-loading='false'
	class:list={[
		iconOnly ? BUTTON_COMPACT_ICON_SECONDARY_CLASS : BUTTON_SECONDARY_CLASS,
		!iconOnly && 'w-full',
		className,
	]}
>
	<svg
		viewBox='0 0 24 24'
		class='h-4 w-4'
		fill='none'
		stroke='currentColor'
		stroke-width='1.8'
		stroke-linecap='round'
		stroke-linejoin='round'
		aria-hidden='true'
		data-refresh-icon='true'
	>
		<path d='M18.9 8.2V4.7h-3.5'></path>
		<path d='M5.1 15.8v3.5h3.5'></path>
		<path d='M7.4 7.8a7 7 0 0 1 10.4-.3l1.1 1.1'></path>
		<path d='M16.6 16.2a7 7 0 0 1-10.4.3l-1.1-1.1'></path>
		<circle cx='12' cy='12' r='1.5' fill='currentColor' stroke='none' opacity='0.18'></circle>
	</svg>
	{iconOnly ? <span class='sr-only'>{label}</span> : label}
</button>

<style>
	button[data-loading='true'] [data-refresh-icon='true'] {
		animation: refresh-button-spin 0.9s linear infinite;
	}

	@keyframes refresh-button-spin {
		to {
			transform: rotate(360deg);
		}
	}
</style>
