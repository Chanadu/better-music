---
interface Props {
	inputId: string;
	name?: string;
	imageId: string;
	emptyId: string;
	label?: string;
	emptyLabel?: string;
	wrapperClassName?: string;
	imageAlt?: string;
}

const {
	inputId,
	name,
	imageId,
	emptyId,
	label = 'Cover Art',
	emptyLabel = 'No cover image selected',
	wrapperClassName = '',
	imageAlt = 'Cover preview',
} = Astro.props as Props;
---

<div class:list={['space-y-2', wrapperClassName]}>
	<input id={inputId} name={name} type="hidden" />
	<p class="text-xs font-semibold uppercase tracking-[0.2em] text-text-muted">{label}</p>
	<div class="overflow-hidden rounded-[1.4rem] border border-border/65 bg-surface-raised/45 p-3">
		<div class="flex min-h-32 items-center justify-center rounded-[1.1rem] border border-dashed border-border/65 bg-surface/85 p-3">
			<img id={imageId} src="" alt={imageAlt} class="hidden h-28 w-28 rounded-xl object-cover shadow-sm sm:h-32 sm:w-32" />
			<p id={emptyId} class="text-center text-sm text-text-muted">{emptyLabel}</p>
		</div>
	</div>
</div>
