---
interface Props {
	inputId: string;
	name?: string;
	imageId: string;
	emptyId: string;
	label?: string;
	emptyLabel?: string;
	wrapperClassName?: string;
	imageAlt?: string;
}

const {
	inputId,
	name,
	imageId,
	emptyId,
	label = 'Cover Art',
	emptyLabel = 'No cover image selected',
	wrapperClassName = '',
	imageAlt = 'Cover preview',
} = Astro.props as Props;
---

<div class:list={['space-y-2', wrapperClassName]}>
	<input id={inputId} name={name} type="hidden" />
	<p class="text-xs font-semibold uppercase tracking-[0.2em] text-text-muted">{label}</p>
	<img
		id={imageId}
		src=""
		alt={imageAlt}
		class="mx-auto hidden h-40 w-40 rounded-2xl object-cover shadow-sm sm:h-44 sm:w-44"
	/>
	<p id={emptyId} class="mx-auto max-w-xs text-center text-sm text-text-muted">{emptyLabel}</p>
</div>
