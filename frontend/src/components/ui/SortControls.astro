---
interface Props {
	controlId: string;
	label?: string;
	containerClass?: string;
}

const {
	controlId,
	label = 'Sort',
	containerClass = 'grid w-auto max-w-full shrink-0 grid-cols-[auto_auto] items-center gap-1.5 sm:grid-cols-[auto_auto_auto] sm:gap-3',
} = Astro.props as Props;

const triggerId = `${controlId}-trigger`;
const valueId = `${controlId}-value`;
const menuId = `${controlId}-menu`;
const directionId = controlId.replace(/-by$/, '-direction');
---

<div class={containerClass}>
	<label
		for={triggerId}
		class='text-text-muted hidden w-8 shrink-0 text-[11px] font-semibold tracking-[0.16em] uppercase sm:block sm:w-11 sm:text-xs sm:tracking-[0.22em]'
	>
		{label}
	</label>
	<div class='relative w-fit max-w-[7.75rem] min-w-0 sm:max-w-[11rem] md:max-w-[13rem]' data-themed-dropdown-root>
		<button
			id={triggerId}
			type='button'
			aria-haspopup='listbox'
			aria-expanded='false'
			class='border-border/70 bg-surface/92 text-text hover:border-primary/30 hover:bg-surface-raised focus:ring-primary/10 inline-flex h-10 w-auto max-w-full min-w-0 items-center justify-between gap-2 rounded-xl border px-3 py-2 text-sm shadow-sm transition-all duration-200 focus:ring-2 sm:h-11 sm:rounded-2xl sm:px-4'
		>
			<span id={valueId} class='max-w-[4.6rem] truncate text-left sm:max-w-[7rem] md:max-w-[9rem]'>Select</span>
			<svg viewBox='0 0 24 24' class='text-text-muted h-4 w-4' aria-hidden='true'
				><path
					d='M6 9l6 6 6-6'
					fill='none'
					stroke='currentColor'
					stroke-width='2'
					stroke-linecap='round'
					stroke-linejoin='round'></path></svg
			>
		</button>
		<div
			id={menuId}
			role='listbox'
			class='border-border/70 bg-surface absolute top-[calc(100%+0.45rem)] left-0 z-30 hidden max-h-64 w-full overflow-y-auto rounded-2xl border p-2 shadow-[var(--shell-shadow)]'
		>
		</div>
	</div>
	<button
		id={directionId}
		type='button'
		aria-label='Sort direction'
		title='Ascending'
		class='border-border/70 bg-surface/92 text-text hover:border-primary/30 hover:bg-surface-raised focus:ring-primary/10 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border transition-all duration-200 focus:ring-2 sm:h-11 sm:w-11 sm:rounded-2xl'
	>
		<svg viewBox='0 0 24 24' class='h-4 w-4' aria-hidden='true'
			><path d='M12 7l-4 6h8z' fill='currentColor'></path></svg
		>
	</button>
</div>
