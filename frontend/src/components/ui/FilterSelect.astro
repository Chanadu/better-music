---
import { BUTTON_COMPACT_SECONDARY_CLASS } from '../../lib/button-styles';

interface Props {
	selectId: string;
	label?: string;
	wrapperClassName?: string;
	selectClassName?: string;
	[name: string]: unknown;
}

const {
	selectId,
	label = 'Filter',
	wrapperClassName = '',
	selectClassName = '',
	...selectProps
} = Astro.props as Props;

const triggerId = `${selectId}-trigger`;
const valueId = `${selectId}-value`;
const menuId = `${selectId}-menu`;
const nativeSelectOverlayClass =
	'peer absolute inset-0 z-10 h-full w-full cursor-pointer appearance-none rounded-xl opacity-0 focus:outline-none disabled:cursor-not-allowed';
---

<div
	class:list={['relative min-w-0', wrapperClassName]}
	data-filter-select-root='true'
>
	<span class='sr-only'>{label}</span>
	<div class='relative hidden' data-filter-native-wrapper='true'>
		<select
			id={selectId}
			class:list={[nativeSelectOverlayClass, selectClassName]}
			data-filter-native-select='true'
			{...selectProps}
		>
			<slot />
		</select>
		<div
			class:list={[
				BUTTON_COMPACT_SECONDARY_CLASS,
				'pointer-events-none relative w-full gap-0 pr-10 text-left peer-focus:ring-2 peer-focus:ring-primary/10 peer-disabled:opacity-50 sm:pr-11',
			]}
		>
			<span data-filter-native-value='true' class='min-w-0 flex-1 truncate text-left'>Select</span>
			<svg
				viewBox='0 0 24 24'
				class='text-text-muted pointer-events-none absolute inset-y-0 right-3 my-auto h-4 w-4 shrink-0 sm:right-4'
				aria-hidden='true'
			>
				<path
					d='M6 9l6 6 6-6'
					fill='none'
					stroke='currentColor'
					stroke-width='2'
					stroke-linecap='round'
					stroke-linejoin='round'
				></path>
			</svg>
		</div>
	</div>
	<div data-themed-dropdown-root data-filter-custom-dropdown='true'>
		<button
			id={triggerId}
			type='button'
			aria-haspopup='listbox'
			aria-expanded='false'
			data-filter-custom-trigger='true'
			class:list={[BUTTON_COMPACT_SECONDARY_CLASS, 'relative w-full gap-0 pr-10 text-left sm:pr-11']}
		>
			<span id={valueId} data-filter-custom-value='true' class='min-w-0 flex-1 truncate text-left'>Select</span>
			<svg
				viewBox='0 0 24 24'
				class='text-text-muted pointer-events-none absolute inset-y-0 right-3 my-auto h-4 w-4 shrink-0 sm:right-4'
				aria-hidden='true'
			>
				<path
					d='M6 9l6 6 6-6'
					fill='none'
					stroke='currentColor'
					stroke-width='2'
					stroke-linecap='round'
					stroke-linejoin='round'
				></path>
			</svg>
		</button>
		<div
			id={menuId}
			role='listbox'
			data-filter-custom-menu='true'
			class='border-border/70 bg-surface absolute top-[calc(100%+0.45rem)] left-0 z-30 hidden max-h-64 w-full overflow-y-auto rounded-2xl border p-2 shadow-[var(--shell-shadow)]'
		></div>
	</div>
</div>

<script>
	import { DROPDOWN_MENU_MODE_EVENT, getDropdownMenuMode } from '../../lib/dropdown-mode';
	import { bindOnce } from '../../lib/events';
	import { createThemedDropdown } from '../../lib/ui';

	bindOnce('__filterSelectBound', () => {
		const syncFilterSelectMode = (container: HTMLDivElement) => {
			const nativeWrapper = container.querySelector(
				'[data-filter-native-wrapper="true"]',
			) as HTMLDivElement | null;
			const customDropdown = container.querySelector(
				'[data-filter-custom-dropdown="true"]',
			) as HTMLDivElement | null;
			const menu = container.querySelector('[data-filter-custom-menu="true"]') as HTMLDivElement | null;
			const useSystemMenus = getDropdownMenuMode() === 'system';

			nativeWrapper?.classList.toggle('hidden', !useSystemMenus);
			customDropdown?.classList.toggle('hidden', useSystemMenus);
			if (useSystemMenus) menu?.classList.add('hidden');
		};

		const bindFilterSelects = () => {
			for (const root of document.querySelectorAll('[data-filter-select-root="true"]')) {
				const container = root as HTMLDivElement;
				const select = container.querySelector('select') as HTMLSelectElement | null;
				const trigger = container.querySelector(
					'[data-filter-custom-trigger="true"]',
				) as HTMLButtonElement | null;
				const nativeValueNode = container.querySelector(
					'[data-filter-native-value="true"]',
				) as HTMLSpanElement | null;
				const valueNode = container.querySelector(
					'[data-filter-custom-value="true"]',
				) as HTMLSpanElement | null;
				const menu = container.querySelector('[data-filter-custom-menu="true"]') as HTMLDivElement | null;
				if (!select || !trigger || !valueNode || !nativeValueNode || !menu) continue;

				if (container.dataset.bound === 'true') {
					syncFilterSelectMode(container);
					continue;
				}
				container.dataset.bound = 'true';

				const controller = createThemedDropdown({
					triggerId: trigger.id,
					valueId: valueNode.id,
					menuId: menu.id,
					onSelect: (value) => {
						select.value = value;
						select.dispatchEvent(new Event('change', { bubbles: true }));
					},
				});
				if (!controller) continue;

				const sync = () => {
					const options = Array.from(select.options).map((option) => ({
						value: option.value,
						label: option.textContent ?? option.value,
					}));
					if (!options.length) return;

					const nextValue =
						options.some((option) => option.value === select.value) ? select.value : options[0].value;
					if (select.value !== nextValue) select.value = nextValue;
					const selectedOption = options.find((option) => option.value === nextValue) ?? options[0];
					nativeValueNode.textContent = selectedOption.label;
					controller.setOptions(options, nextValue);
				};

				const observer = new MutationObserver(() => sync());
				observer.observe(select, {
					childList: true,
					subtree: true,
					attributes: true,
					attributeFilter: ['selected', 'label', 'value'],
				});

				select.addEventListener('change', sync);
				select.addEventListener('themed-select-sync', sync as EventListener);
				sync();
				syncFilterSelectMode(container);
			}
		};

		document.addEventListener('astro:page-load', bindFilterSelects);
		window.addEventListener(DROPDOWN_MENU_MODE_EVENT, bindFilterSelects);
		bindFilterSelects();
	});
</script>
