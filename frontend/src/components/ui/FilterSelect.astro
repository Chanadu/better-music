---
import { DROPDOWN_ROW_TRIGGER_CLASS } from '../../lib/button-styles';

interface Props {
	selectId: string;
	label?: string;
	wrapperClassName?: string;
	selectClassName?: string;
	[name: string]: unknown;
}

const {
	selectId,
	label = 'Filter',
	wrapperClassName = '',
	selectClassName = '',
	...selectProps
} = Astro.props as Props;

const triggerId = `${selectId}-trigger`;
const valueId = `${selectId}-value`;
const menuId = `${selectId}-menu`;
const nativeSelectOverlayClass =
	'peer absolute inset-0 z-10 h-full w-full cursor-pointer appearance-none rounded-xl opacity-0 focus:outline-none disabled:cursor-not-allowed';
---

<div class:list={['grid min-w-0 grid-cols-1 items-center gap-1.5 sm:grid-cols-[auto_minmax(0,1fr)] sm:gap-3', wrapperClassName]}>
	<label
		for={triggerId}
		class='text-text-muted hidden shrink-0 whitespace-nowrap text-[11px] font-semibold tracking-[0.16em] uppercase sm:block sm:text-xs sm:tracking-[0.22em]'
	>
		{label}
	</label>
	<div class='relative min-w-0' data-filter-select-root='true' data-themed-dropdown-root>
		<span class='sr-only'>{label}</span>
		<select
			id={selectId}
			class:list={[nativeSelectOverlayClass, selectClassName]}
			data-filter-native-select='true'
			{...selectProps}
		>
			<slot />
		</select>
		<button
			id={triggerId}
			type='button'
			aria-haspopup='listbox'
			aria-expanded='false'
			data-filter-custom-trigger='true'
			class:list={[
				DROPDOWN_ROW_TRIGGER_CLASS,
				'relative gap-0 pr-10 peer-focus-visible:border-primary/25 peer-focus-visible:ring-2 peer-focus-visible:ring-primary/10 sm:pr-11',
			]}
		>
			<span id={valueId} data-filter-custom-value='true' class='min-w-0 flex-1 truncate text-left'>Select</span>
			<svg
				viewBox='0 0 24 24'
				data-dropdown-chevron='true'
				class='text-text-muted pointer-events-none absolute inset-y-0 right-3 my-auto h-4 w-4 shrink-0 transition-transform duration-200 sm:right-4'
				aria-hidden='true'
			>
				<path
					d='M6 9l6 6 6-6'
					fill='none'
					stroke='currentColor'
					stroke-width='2'
					stroke-linecap='round'
					stroke-linejoin='round'
				></path>
			</svg>
		</button>
		<div
			id={menuId}
			role='listbox'
			data-filter-custom-menu='true'
			class='border-border/75 bg-surface/96 absolute top-[calc(100%+0.55rem)] left-0 z-30 hidden max-h-72 w-full overflow-y-auto rounded-[1.35rem] border p-1.5 shadow-[0_24px_54px_-28px_rgba(15,23,42,0.58)] ring-1 ring-white/55 backdrop-blur-xl dark:ring-white/6'
		></div>
	</div>
</div>

<script>
	import { DROPDOWN_MENU_MODE_EVENT, getDropdownMenuMode } from '../../lib/dropdown-mode';
	import { bindOnce } from '../../lib/events';
	import { createThemedDropdown } from '../../lib/ui';

	bindOnce('__filterSelectBound', () => {
		const syncFilterSelectMode = (container: HTMLDivElement) => {
			const select = container.querySelector('[data-filter-native-select="true"]') as HTMLSelectElement | null;
			const trigger = container.querySelector(
				'[data-filter-custom-trigger="true"]',
			) as HTMLButtonElement | null;
			const menu = container.querySelector('[data-filter-custom-menu="true"]') as HTMLDivElement | null;
			const useSystemMenus = getDropdownMenuMode() === 'system';

			if (select) {
				select.classList.toggle('pointer-events-none', !useSystemMenus);
				select.tabIndex = useSystemMenus ? 0 : -1;
				select.setAttribute('aria-hidden', useSystemMenus ? 'false' : 'true');
			}
			if (trigger) {
				trigger.classList.toggle('pointer-events-none', useSystemMenus);
				trigger.tabIndex = useSystemMenus ? -1 : 0;
				trigger.setAttribute('aria-hidden', useSystemMenus ? 'true' : 'false');
			}
			if (useSystemMenus) menu?.classList.add('hidden');
		};

		const bindFilterSelects = () => {
			for (const root of document.querySelectorAll('[data-filter-select-root="true"]')) {
				const container = root as HTMLDivElement;
				const select = container.querySelector('select') as HTMLSelectElement | null;
				const trigger = container.querySelector(
					'[data-filter-custom-trigger="true"]',
				) as HTMLButtonElement | null;
				const valueNode = container.querySelector(
					'[data-filter-custom-value="true"]',
				) as HTMLSpanElement | null;
				const menu = container.querySelector('[data-filter-custom-menu="true"]') as HTMLDivElement | null;
				if (!select || !trigger || !valueNode || !menu) continue;

				if (container.dataset.bound === 'true') {
					syncFilterSelectMode(container);
					continue;
				}
				container.dataset.bound = 'true';

				const controller = createThemedDropdown({
					triggerId: trigger.id,
					valueId: valueNode.id,
					menuId: menu.id,
					onSelect: (value) => {
						select.value = value;
						select.dispatchEvent(new Event('change', { bubbles: true }));
					},
				});
				if (!controller) continue;

				const sync = () => {
					const options = Array.from(select.options).map((option) => ({
						value: option.value,
						label: option.textContent ?? option.value,
					}));
					if (!options.length) return;

					const nextValue =
						options.some((option) => option.value === select.value) ? select.value : options[0].value;
					if (select.value !== nextValue) select.value = nextValue;
					controller.setOptions(options, nextValue);
				};

				const observer = new MutationObserver(() => sync());
				observer.observe(select, {
					childList: true,
					subtree: true,
					attributes: true,
					attributeFilter: ['selected', 'label', 'value'],
				});

				select.addEventListener('change', sync);
				select.addEventListener('themed-select-sync', sync as EventListener);
				sync();
				syncFilterSelectMode(container);
			}
		};

		document.addEventListener('astro:page-load', bindFilterSelects);
		window.addEventListener(DROPDOWN_MENU_MODE_EVENT, bindFilterSelects);
		bindFilterSelects();
	});
</script>
