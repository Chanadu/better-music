---
interface Props {
	title: string;
	modalId?: string;
}

const { title } = Astro.props;
---

<div class="flex items-center justify-start">
	<div>
		<p class="mb-1 text-[11px] font-semibold uppercase tracking-[0.24em] text-text-muted">Create</p>
		<h3 class="text-xl font-semibold tracking-tight text-text">{title}</h3>
	</div>
</div>
