---
import ThemeToggleButton from './ThemeToggleButton.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<header class="sticky top-0 z-30 w-full border-b border-border/50 bg-bg/85 shadow-sm backdrop-blur-xl transition-all">
	<div class="mx-auto flex max-w-4xl items-center justify-between px-4 pb-3 pt-[max(0.75rem,env(safe-area-inset-top))] sm:px-6 md:px-8">
		<div class="flex items-center gap-3">
			<div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary text-primary-fg shadow-md">
				<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
					<path d="M9 18a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Zm11-2a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Z"></path>
					<path d="M9 18V6l11-2v12"></path>
					<path d="M9 10l11-2"></path>
				</svg>
			</div>
			<h1 class="text-xl font-extrabold tracking-tight text-text sm:text-2xl">{title}</h1>
		</div>

		<div class="flex items-center gap-3">
			<ThemeToggleButton />
			<button
				data-logout-button
				class="flex cursor-pointer items-center justify-center rounded-lg border-2 border-border bg-surface px-3 py-2 text-text shadow-sm transition-all hover:-translate-y-0.5 hover:shadow hover:opacity-90 active:scale-95"
				aria-label="Log out"
			>
				<svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
					<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
					<path d="M16 17l5-5-5-5"></path>
					<path d="M21 12H9"></path>
				</svg>
			</button>
		</div>
	</div>
</header>

<script>
	import { navigate } from 'astro:transitions/client';
import { logout } from '../../lib/api';

	document.querySelectorAll<HTMLButtonElement>('[data-logout-button]').forEach((button) => {
		button.addEventListener('click', async () => {
			await logout();
			void navigate('/login');
		});
	});
</script>
