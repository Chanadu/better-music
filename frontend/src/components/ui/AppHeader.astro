---
import HeaderSettingsMenu from './HeaderSettingsMenu.astro';
import type { HeaderCountType } from '../../lib/library-stats';

interface Props {
	title: string;
	countType?: HeaderCountType;
}

const { title, countType } = Astro.props as Props;
const HEADER_COUNT_CHIP_CLASS =
	'inline-flex h-11 min-w-[3.35rem] shrink-0 items-center justify-center rounded-2xl border border-border/70 bg-surface/92 px-4 text-sm font-semibold text-text shadow-sm';
---

<header
	class='border-border/50 bg-surface/78 sticky top-0 z-30 w-full border-b shadow-[0_10px_30px_-24px_rgba(15,23,42,0.45)] backdrop-blur-xl transition-all'
>
	<div
		class='mx-auto flex max-w-5xl items-center justify-between gap-3 px-4 pt-[max(0.75rem,env(safe-area-inset-top))] pb-3 sm:px-6 md:px-8'
	>
		<div class='flex min-w-0 items-center gap-3 sm:gap-4'>
			<div
				class='from-primary to-primary-hover text-primary-fg flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-linear-to-br shadow-[var(--shell-shadow)]'
			>
				<svg
					viewBox='0 0 24 24'
					class='h-6 w-6'
					fill='none'
					stroke='currentColor'
					stroke-width='1.8'
					aria-hidden='true'
				>
					<path d='M9 18a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Zm11-2a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Z'
					></path>
					<path d='M9 18V6l11-2v12'></path>
					<path d='M9 10l11-2'></path>
				</svg>
			</div>
			<div class='min-w-0'>
				<p class='text-text-muted hidden text-[11px] font-semibold tracking-[0.22em] uppercase sm:block'>
					Better Music
				</p>
				<h1 class='text-text mt-0.5 min-w-0 truncate text-xl font-extrabold tracking-tight sm:text-[1.65rem]'>
					{title}
				</h1>
			</div>
		</div>

		<div class='flex items-center gap-2 sm:gap-3'>
			{
				countType && (
					<div
						class={HEADER_COUNT_CHIP_CLASS}
						data-app-header-count-root='true'
						data-app-header-count-type={countType}
					>
						<span
							class='tabular-nums'
							data-app-header-count-value='true'
						>
							--
						</span>
					</div>
				)
			}
			<HeaderSettingsMenu />
		</div>
	</div>
</header>

<script>
	import { loadLibraryData } from '../../lib/library-cache';
	import { bindOnce } from '../../lib/events';
	import {
		LIBRARY_DATA_CHANGED_EVENT,
		getHeaderCountMeta,
		getLibraryStats,
		type HeaderCountType,
	} from '../../lib/library-stats';

	const formatCount = (value: number) => value.toLocaleString();

	const getHeaderCountRoot = () =>
		document.querySelector('[data-app-header-count-root="true"]') as HTMLDivElement | null;
	const getHeaderCountValue = () =>
		document.querySelector('[data-app-header-count-value="true"]') as HTMLSpanElement | null;

	const getHeaderCountType = (): HeaderCountType | null => {
		const type = getHeaderCountRoot()?.dataset.appHeaderCountType;
		return type === 'artists' || type === 'queuedAlbums' || type === 'doneAlbums' ? type : null;
	};

	const syncHeaderCount = async () => {
		const root = getHeaderCountRoot();
		const type = getHeaderCountType();
		const value = getHeaderCountValue();
		if (!root || !type || !value) return;

		try {
			const stats = getLibraryStats(await loadLibraryData());
			const countMeta = getHeaderCountMeta(type, stats);
			const formattedCount = formatCount(countMeta.value);
			value.textContent = formattedCount;
			root.setAttribute('aria-label', `${formattedCount} ${countMeta.label}`);
			root.title = `${formattedCount} ${countMeta.label}`;
		} catch {
			// Keep the fallback copy when library data is not available yet.
		}
	};

	bindOnce('__appHeaderCountBound', () => {
		document.addEventListener('astro:page-load', () => {
			void syncHeaderCount();
		});
		window.addEventListener(LIBRARY_DATA_CHANGED_EVENT, () => {
			void syncHeaderCount();
		});
		void syncHeaderCount();
	});
</script>
