---
import ThemeToggleButton from './ThemeToggleButton.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<header
	class='border-border/50 bg-surface/78 sticky top-0 z-30 w-full border-b shadow-[0_10px_30px_-24px_rgba(15,23,42,0.45)] backdrop-blur-xl transition-all'
>
	<div
		class='mx-auto flex max-w-5xl items-center justify-between gap-3 px-4 pt-[max(0.75rem,env(safe-area-inset-top))] pb-3 sm:px-6 md:px-8'
	>
		<div class='flex min-w-0 items-center gap-3 sm:gap-4'>
			<div
				class='from-primary to-primary-hover text-primary-fg flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-linear-to-br shadow-[var(--shell-shadow)]'
			>
				<svg
					viewBox='0 0 24 24'
					class='h-6 w-6'
					fill='none'
					stroke='currentColor'
					stroke-width='1.8'
					aria-hidden='true'
				>
					<path d='M9 18a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Zm11-2a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Z'
					></path>
					<path d='M9 18V6l11-2v12'></path>
					<path d='M9 10l11-2'></path>
				</svg>
			</div>
			<div class='min-w-0'>
				<p class='text-text-muted hidden text-[11px] font-semibold tracking-[0.22em] uppercase sm:block'>
					Better Music
				</p>
				<h1 class='text-text truncate text-xl font-extrabold tracking-tight sm:text-[1.65rem]'>{title}</h1>
			</div>
		</div>

		<div class='flex items-center gap-2 sm:gap-3'>
			<ThemeToggleButton />
			<button
				data-logout-button
				class='ui-pressable border-border/70 bg-surface/92 text-text hover:border-primary/25 hover:bg-surface-raised flex h-11 cursor-pointer items-center justify-center gap-2 rounded-2xl border px-3 shadow-sm active:scale-95 sm:px-4'
				aria-label='Log out'
			>
				<svg
					viewBox='0 0 24 24'
					class='h-5 w-5'
					fill='none'
					stroke='currentColor'
					stroke-width='1.8'
					aria-hidden='true'
				>
					<path d='M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4'></path>
					<path d='M16 17l5-5-5-5'></path>
					<path d='M21 12H9'></path>
				</svg>
				<span class='hidden text-sm font-semibold sm:inline'>Log out</span>
			</button>
		</div>
	</div>
</header>

<script>
	import { LOGIN_PATH, logout } from '../../lib/api';
	import { bindOnce } from '../../lib/events';

	bindOnce('__logoutBound', () => {
		document.addEventListener('click', async (event) => {
			const target = event.target as Element | null;
			if (target?.closest('[data-logout-button]')) {
				await logout();
				window.location.replace(LOGIN_PATH);
			}
		});
	});
</script>
