---
interface Props {
	id: string;
	label: string;
	wrapperClassName?: string;
	selectClassName?: string;
	labelClassName?: string;
	[name: string]: unknown;
}

const {
	id,
	label,
	wrapperClassName = '',
	selectClassName = '',
	labelClassName = '',
	...selectProps
} = Astro.props as Props;

const baseSelectClass =
	'w-full rounded-xl border border-border/60 bg-surface-raised/50 px-4 pb-2 pt-6 text-base text-text transition-all duration-200 focus:border-primary/60 focus:bg-surface-raised focus:outline-none focus:ring-4 focus:ring-primary/10';
const baseLabelClass = 'pointer-events-none absolute left-4 top-2 text-xs font-semibold text-text-muted';
---

<div class:list={['relative', wrapperClassName]}>
	<select id={id} class:list={[baseSelectClass, selectClassName]} {...selectProps}>
		<slot />
	</select>
	<label for={id} class:list={[baseLabelClass, labelClassName]}>
		{label}
	</label>
</div>
