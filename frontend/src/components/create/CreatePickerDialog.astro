---
import CreateOptionCard from './CreateOptionCard.astro';
import ModalHeader from '../ui/ModalHeader.astro';
import BaseDialog from '../ui/BaseDialog.astro';
---

<BaseDialog
	id="create-picker-modal"
	className="w-[min(92vw,30rem)] m-auto rounded-[2rem] border border-border/70 bg-linear-to-br from-surface via-surface to-surface-raised/45 p-0 text-text shadow-[var(--shell-shadow)] backdrop:bg-black/40"
	contentClassName="space-y-5 p-5 sm:space-y-6 sm:p-6"
	mobilePlacement="top"
>
		<ModalHeader title="Choose What To Create" />
		<p class="text-sm leading-6 text-text-muted">Start with the kind of entry you want to add, then fill it in manually or pull details from Spotify.</p>

		<div class="grid gap-3 sm:grid-cols-2">
			<CreateOptionCard id="open-artist-modal" label="Artist">
				<svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
					<circle cx="12" cy="7" r="4"></circle>
					<path d="M4 21c0-4.2 3.6-7 8-7s8 2.8 8 7"></path>
				</svg>
			</CreateOptionCard>

			<CreateOptionCard id="open-album-modal" label="Album">
				<svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
					<circle cx="12" cy="12" r="8"></circle>
					<circle cx="12" cy="12" r="2"></circle>
				</svg>
			</CreateOptionCard>
		</div>
</BaseDialog>

<script>
	import { closeDialogSafely, openDialogSafely } from '../../lib/dialog';
	import { bindOnce } from '../../lib/events';

	const getCreatePicker = () => document.getElementById('create-picker-modal') as HTMLDialogElement | null;

	bindOnce('__createPickerOpenBound', () => {
		window.addEventListener('open-create-menu', () => {
			requestAnimationFrame(() => openDialogSafely(getCreatePicker()));
		});
	});

	bindOnce('__createPickerClickBound', () => {
		document.addEventListener('click', (event) => {
			const target = event.target as Element | null;
			const createPicker = getCreatePicker();

			if (target?.closest('#open-artist-modal')) {
				closeDialogSafely(createPicker);
				requestAnimationFrame(() => window.dispatchEvent(new CustomEvent('open-artist-modal')));
				return;
			}

			if (target?.closest('#open-album-modal')) {
				closeDialogSafely(createPicker);
				requestAnimationFrame(() => window.dispatchEvent(new CustomEvent('open-album-modal')));
			}
		});
	});
</script>
