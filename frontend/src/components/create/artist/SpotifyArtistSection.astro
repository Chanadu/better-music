---
import SearchBar from '../../nav/SearchBar.astro';
import SpotifyArtistResultItem from './SpotifyArtistResultItem.astro';
---

<div role='tabpanel' class='tab-content px-2 pt-3' data-spotify-artist-section>
	<fieldset class='fieldset'>
		<SearchBar placeholder='Search artists' />
	</fieldset>

	<ul class='list bg-base-200 rounded-box mt-4 shadow-md' data-spotify-artist-results>
		{Array.from({ length: 5 }, () => <SpotifyArtistResultItem />)}
	</ul>
</div>

<script>
	import { spotifyApi } from '../../../scripts/api';
	import type { SpotifyArtistSearchResult } from '../../../scripts/api-types';

	const section = document.querySelector<HTMLElement>('[data-spotify-artist-section]');
	const searchInput = section?.querySelector<HTMLInputElement>('input[type="search"]');
	const resultsList = section?.querySelector<HTMLUListElement>('[data-spotify-artist-results]');
	let searchTimeout: number | undefined;
	let latestRequest = 0;
	const resultRows = Array.from(
		resultsList?.querySelectorAll<HTMLLIElement>('[data-spotify-artist-result-item]') ?? [],
	);

	const getArtistImage = (artist: SpotifyArtistSearchResult) => artist.images[0]?.url;

	type ArtistRowData = {
		id: string;
		name: string;
		imageUrl?: string;
		disabled?: boolean;
	};

	let selectedArtist: ArtistRowData | undefined;

	const updateArtistRow = (row: HTMLLIElement, { id, name, imageUrl, disabled = false }: ArtistRowData) => {
		const label = row.querySelector<HTMLLabelElement>('label');
		const input = row.querySelector<HTMLInputElement>('[data-spotify-artist-input]');
		const image = row.querySelector<HTMLImageElement>('[data-spotify-artist-image]');
		const fallback = row.querySelector<HTMLElement>('[data-spotify-artist-fallback]');
		const artistName = row.querySelector<HTMLElement>('[data-spotify-artist-name]');
		const isSelectedArtist = selectedArtist?.id === id && !disabled;

		row.dataset.spotifyArtistId = id;
		row.dataset.spotifyArtistName = name;
		row.dataset.spotifyArtistImageUrl = imageUrl ?? '';

		if (input) {
			input.value = id;
			input.disabled = disabled;
			input.checked = isSelectedArtist;
			input.onclick = () => {
				if (selectedArtist?.id !== id) return;

				selectedArtist = undefined;
				input.checked = false;
				input.dispatchEvent(new Event('change', { bubbles: true }));
			};
		}

		if (label) {
			label.classList.toggle('cursor-pointer', !disabled);
			label.classList.toggle('cursor-default', disabled);
		}

		if (image && fallback) {
			if (imageUrl) {
				image.src = imageUrl;
				image.alt = `${name} artist image`;
				image.hidden = false;
				fallback.hidden = true;
			} else {
				image.hidden = true;
				fallback.hidden = false;
			}
		}

		if (artistName) {
			artistName.textContent = name;
			artistName.classList.toggle('text-base-content/35', disabled);
		}
	};

	const keepSelectedArtistVisible = (index: number) => {
		if (!selectedArtist) return;
		if (resultRows.some((row) => row.dataset.spotifyArtistId === selectedArtist?.id)) return;

		const row = resultRows[index];
		if (row) updateArtistRow(row, selectedArtist);
	};

	const renderPlaceholderArtists = (message: string) => {
		resultRows.forEach((row, index) => {
			updateArtistRow(row, {
				id: `placeholder-${index}`,
				name: message,
				disabled: true,
			});
		});

		keepSelectedArtistVisible(0);
	};

	const renderArtists = (artists: SpotifyArtistSearchResult[]) => {
		const visibleArtists =
			selectedArtist && !artists.some((artist) => artist.id === selectedArtist?.id) ?
				artists.slice(0, 4)
			:	artists;

		resultRows.forEach((row, index) => {
			const artist = visibleArtists[index];

			if (!artist) {
				updateArtistRow(row, {
					id: `empty-${index}`,
					name: '',
					disabled: true,
				});
				return;
			}

			updateArtistRow(row, {
				id: artist.id,
				name: artist.name,
				imageUrl: getArtistImage(artist),
			});
		});

		keepSelectedArtistVisible(resultRows.length - 1);
	};

	const searchArtists = async () => {
		const query = searchInput?.value.trim() ?? '';
		const requestId = ++latestRequest;

		if (!resultsList) return;

		if (query.length === 0) {
			renderPlaceholderArtists('Start searching...');
			return;
		}

		renderPlaceholderArtists('Searching Spotify...');

		try {
			const artists = await spotifyApi.searchArtists(query, 5);
			if (requestId !== latestRequest) return;

			if (artists.length === 0) {
				renderPlaceholderArtists('No artists found.');
				return;
			}

			renderArtists(artists);
		} catch {
			if (requestId !== latestRequest) return;
			renderPlaceholderArtists('Spotify search failed.');
		}
	};

	searchInput?.addEventListener('input', () => {
		window.clearTimeout(searchTimeout);
		searchTimeout = window.setTimeout(searchArtists, 250);
	});

	resultsList?.addEventListener('change', (event) => {
		const input = event.target;
		if (!(input instanceof HTMLInputElement) || input.name !== 'spotify_artist') return;

		if (!input.checked) {
			selectedArtist = undefined;
			return;
		}

		const row = input.closest<HTMLLIElement>('[data-spotify-artist-result-item]');
		if (!row || input.disabled) return;

		selectedArtist = {
			id: row.dataset.spotifyArtistId ?? input.value,
			name: row.dataset.spotifyArtistName ?? '',
			imageUrl: row.dataset.spotifyArtistImageUrl || undefined,
		};
	});

	renderPlaceholderArtists('Start searching...');
</script>
