---
import BaseModal from '../BaseModal.astro';
import ErrorAlert from '../../ErrorAlert.astro';
import ManualArtistSection from './ManualArtistSection.astro';
import SpotifyArtistSection from './SpotifyArtistSection.astro';
---

<BaseModal title='Create Artist'>
	<div role='tablist' class='tabs tabs-border flex'>
		<input
			data-manual-artist-tab
			type='radio'
			name='modal_tabs'
			role='tab'
			class='tab w-full flex-1'
			aria-label='Manual'
			checked
		/>
		<ManualArtistSection />

		<input
			data-spotify-artist-tab
			type='radio'
			name='modal_tabs'
			role='tab'
			class='tab w-full flex-1'
			aria-label='Spotify'
		/>
		<SpotifyArtistSection />
	</div>

	<ErrorAlert />

	<div class='modal-action mt-6 flex gap-4 px-2'>
		<form method='dialog' class='flex-1'>
			<button class='btn btn-soft btn-secondary w-full'>Cancel</button>
		</form>
		<button type='button' class='btn btn-primary flex-1' data-save-artist-button disabled>Save Artist</button>
	</div>
</BaseModal>

<script>
	import { artistsApi } from '../../../scripts/api';
	import { refreshDatabaseData } from '../../../scripts/database';

	const createModal = document.querySelector<HTMLDialogElement>('[data-create-modal]');
	const saveArtistButton = document.querySelector<HTMLButtonElement>('[data-save-artist-button]');
	const manualArtistNameInput = document.querySelector<HTMLInputElement>('[data-manual-artist-name-input]');
	const manualArtistTab = document.querySelector<HTMLInputElement>('[data-manual-artist-tab]');
	const spotifyArtistTab = document.querySelector<HTMLInputElement>('[data-spotify-artist-tab]');
	const errorAlert = document.querySelector<HTMLElement>('[data-error-alert]');
	const errorAlertMessage = document.querySelector<HTMLElement>('[data-error-alert-message]');
	let isSavingArtist = false;

	const showError = (message: string) => {
		if (errorAlertMessage) {
			errorAlertMessage.textContent = message;
		}

		errorAlert?.classList.remove('hidden');
	};

	const hideError = () => {
		errorAlert?.classList.add('hidden');
	};

	const formatErrorMessage = (error: unknown) => {
		const message = error instanceof Error ? error.message : 'Failed to save artist';
		const normalizedMessage = message.trim().replace(/\s+/g, ' ');
		if (!normalizedMessage) return 'Failed to save artist';

		return normalizedMessage.charAt(0).toUpperCase() + normalizedMessage.slice(1);
	};

	const updateSaveArtistButton = () => {
		const hasManualName = (manualArtistNameInput?.value.trim().length ?? 0) > 0;
		const hasSpotifyArtist = document.querySelector<HTMLInputElement>(
			'input[name="spotify_artist"]:checked:not(:disabled)',
		);

		if (saveArtistButton) {
			saveArtistButton.disabled =
				isSavingArtist || (manualArtistTab?.checked ? !hasManualName : !hasSpotifyArtist);
		}
	};

	const getSelectedSpotifyArtist = () => {
		const selectedSpotifyInput = document.querySelector<HTMLInputElement>(
			'input[name="spotify_artist"]:checked:not(:disabled)',
		);
		const selectedSpotifyRow = selectedSpotifyInput?.closest<HTMLElement>('[data-spotify-artist-result-item]');

		if (!selectedSpotifyInput || !selectedSpotifyRow) return undefined;

		return {
			name: selectedSpotifyRow.dataset.spotifyArtistName ?? '',
			cover_url: selectedSpotifyRow.dataset.spotifyArtistImageUrl || undefined,
			spotify_id: selectedSpotifyRow.dataset.spotifyArtistId ?? selectedSpotifyInput.value,
		};
	};

	const resetCreateArtistModal = () => {
		if (manualArtistNameInput) {
			manualArtistNameInput.value = '';
		}

		document.querySelector<HTMLInputElement>('input[name="spotify_artist"]:checked')?.click();
		document.dispatchEvent(new CustomEvent('create-artist-modal-reset'));
		hideError();
		updateSaveArtistButton();
	};

	saveArtistButton?.addEventListener('click', async () => {
		const artist =
			manualArtistTab?.checked ?
				{
					name: manualArtistNameInput?.value.trim() ?? '',
				}
			:	getSelectedSpotifyArtist();

		if (!artist?.name) return;

		isSavingArtist = true;
		hideError();
		saveArtistButton.textContent = 'Saving...';
		updateSaveArtistButton();

		try {
			await artistsApi.create(artist);
			await refreshDatabaseData();
			createModal?.close();
			resetCreateArtistModal();
		} catch (error) {
			console.error('Failed to save artist', error);
			showError(formatErrorMessage(error));
		} finally {
			isSavingArtist = false;
			saveArtistButton.textContent = 'Save Artist';
			updateSaveArtistButton();
		}
	});

	manualArtistNameInput?.addEventListener('input', updateSaveArtistButton);
	manualArtistTab?.addEventListener('change', updateSaveArtistButton);
	spotifyArtistTab?.addEventListener('change', updateSaveArtistButton);
	document.addEventListener('change', (event) => {
		const input = event.target;
		if (input instanceof HTMLInputElement && input.name === 'spotify_artist') {
			updateSaveArtistButton();
		}
	});

	updateSaveArtistButton();
</script>
