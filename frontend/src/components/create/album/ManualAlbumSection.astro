---
import FloatingInput from '../../FloatingInput.astro';
---

<div role='tabpanel' class='tab-content px-2 pt-4'>
	<div class='flex flex-col gap-3'>
		<FloatingInput label='Artist'>
			<select data-manual-album-artist-select class='select w-full'>
				<option value=''>Select artist</option>
			</select>
		</FloatingInput>

		<div class='flex items-center gap-4'>
			<div class='basis-1/3 pt-3'>
				<div
					class='rounded-box bg-base-300 flex aspect-square w-full items-center justify-center text-4xl font-semibold'
				>
					<span data-manual-album-preview-initial></span>
				</div>
			</div>

			<div class='flex min-w-0 flex-1 flex-col gap-3'>
				<FloatingInput label='Album Title'>
					<input
						data-manual-album-title-input
						type='text'
						class='input w-full'
						placeholder='e.g. 2014 Forest Hills Drive'
					/>
				</FloatingInput>

				<FloatingInput label='Year'>
					<input
						data-manual-album-year-input
						type='text'
						inputmode='numeric'
						pattern='[0-9]{4}'
						maxlength='4'
						class='input w-full'
						placeholder='2014'
					/>
					<div class='validator-hint hidden'>Enter a valid year</div>
				</FloatingInput>
			</div>
		</div>

		<FloatingInput label='Comment'>
			<textarea data-manual-album-comment-input class='textarea w-full' placeholder='Classic album'></textarea>
		</FloatingInput>
	</div>
</div>
