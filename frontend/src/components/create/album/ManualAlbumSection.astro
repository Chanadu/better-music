<div role='tabpanel' class='tab-content px-2 pt-3'>
	<div class='flex flex-col gap-2'>
		<fieldset class='fieldset'>
			<legend class='fieldset-legend'>Album Title</legend>
			<input
				data-manual-album-title-input
				type='text'
				class='input w-full'
				placeholder='e.g. 2014 Forest Hills Drive'
			/>
		</fieldset>

		<fieldset class='fieldset'>
			<legend class='fieldset-legend'>Artist</legend>
			<select data-manual-album-artist-select class='select w-full'>
				<option value=''>Select artist</option>
			</select>
		</fieldset>

		<fieldset class='fieldset'>
			<legend class='fieldset-legend'>Preview</legend>
			<div class='flex justify-center'>
				<div class='rounded-box bg-base-300 size-44 sm:size-56'></div>
			</div>
		</fieldset>
	</div>
</div>
