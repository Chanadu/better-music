---
import ErrorAlert from '../../ErrorAlert.astro';
import BaseModal from '../BaseModal.astro';
import ManualAlbumSection from './ManualAlbumSection.astro';
import SpotifyAlbumSection from './SpotifyAlbumSection.astro';
---

<BaseModal title='Create Album'>
	<div role='tablist' class='tabs tabs-border flex'>
		<input
			data-manual-album-tab
			type='radio'
			name='album_modal_tabs'
			role='tab'
			class='tab flex-1'
			aria-label='Manual'
			checked
		/>
		<ManualAlbumSection />

		<input
			data-spotify-album-tab
			type='radio'
			name='album_modal_tabs'
			role='tab'
			class='tab flex-1'
			aria-label='Spotify'
		/>
		<SpotifyAlbumSection />
	</div>

	<ErrorAlert />

	<div class='modal-action mt-6 flex gap-4 px-2'>
		<form method='dialog' class='flex-1'>
			<button class='btn btn-soft btn-secondary w-full'>Cancel</button>
		</form>
		<button type='button' class='btn btn-primary flex-1' data-save-album-button disabled>Save Album</button>
	</div>
</BaseModal>

<script>
	import { albumsApi } from '../../../scripts/api';
	import { fetchDatabaseData, refreshDatabaseData } from '../../../scripts/database';
	import { createErrorAlert } from '../../../scripts/error-alert';
	import type { Artist } from '../../../scripts/api-types';

	const createModal = document.querySelector<HTMLDialogElement>('[data-create-modal]');
	const saveAlbumButton = document.querySelector<HTMLButtonElement>('[data-save-album-button]');
	const manualAlbumTab = document.querySelector<HTMLInputElement>('[data-manual-album-tab]');
	const spotifyAlbumTab = document.querySelector<HTMLInputElement>('[data-spotify-album-tab]');
	const listenedFields = document.querySelector<HTMLElement>('[data-manual-album-listened-fields]');
	const ratingMarkers = document.querySelectorAll<HTMLElement>('[data-rating-marker]');
	const ratingValues = document.querySelectorAll<HTMLElement>('[data-rating-value]');
	const albumPreviewInitial = document.querySelector<HTMLElement>('[data-manual-album-preview-initial]');
	const errorAlert = createErrorAlert();
	let isSavingAlbum = false;

	const fields = {
		title: document.querySelector<HTMLInputElement>('[data-manual-album-title-input]'),
		artist: document.querySelector<HTMLSelectElement>('[data-manual-album-artist-select]'),
		year: document.querySelector<HTMLInputElement>('[data-manual-album-year-input]'),
		ratingSlider: document.querySelector<HTMLInputElement>('[data-manual-album-rating-slider]'),
		listened: document.querySelector<HTMLInputElement>('[data-manual-album-listened-input]'),
		listenedAt: document.querySelector<HTMLInputElement>('[data-manual-album-listened-at-input]'),
		comment: document.querySelector<HTMLTextAreaElement>('[data-manual-album-comment-input]'),
	};

	const updateSaveAlbumButton = () => {
		const hasTitle = (fields.title?.value.trim().length ?? 0) > 0;
		const hasArtist = (fields.artist?.value.length ?? 0) > 0;
		const hasValidYear = fields.year?.checkValidity() ?? true;

		if (saveAlbumButton) {
			saveAlbumButton.disabled = isSavingAlbum || !manualAlbumTab?.checked || !hasTitle || !hasArtist || !hasValidYear;
		}
	};

	const setSavingAlbum = (isSaving: boolean) => {
		isSavingAlbum = isSaving;

		if (saveAlbumButton) {
			saveAlbumButton.textContent = isSaving ? 'Saving...' : 'Save Album';
		}

		updateSaveAlbumButton();
	};

	const getTodayDateValue = () => {
		const today = new Date();
		const year = today.getFullYear();
		const month = String(today.getMonth() + 1).padStart(2, '0');
		const day = String(today.getDate()).padStart(2, '0');

		return `${year}-${month}-${day}`;
	};

	const updateListenedFields = () => {
		const isListened = fields.listened?.checked ?? false;

		listenedFields?.classList.toggle('opacity-40', !isListened);
		fields.ratingSlider && (fields.ratingSlider.disabled = !isListened);
		fields.listenedAt && (fields.listenedAt.disabled = !isListened);

		if (isListened && fields.listenedAt && !fields.listenedAt.value) {
			fields.listenedAt.value = getTodayDateValue();
		}
	};

	const updateRatingMeasure = () => {
		const rating = fields.ratingSlider?.value ?? '5';

		ratingMarkers.forEach((marker) => {
			const isSelected = marker.dataset.ratingMarker === rating;
			marker.textContent = isSelected ? '↓' : '|';
			marker.classList.toggle('text-accent', isSelected);
		});

		ratingValues.forEach((value) => {
			value.classList.toggle('text-accent', value.dataset.ratingValue === rating);
			value.classList.toggle('text-xl', value.dataset.ratingValue === rating);
		});
	};

	const updateYearValidity = () => {
		if (!fields.year) return;

		fields.year.value = fields.year.value.replace(/\D/g, '');

		const year = Number(fields.year.value);
		const currentYear = new Date().getFullYear();
		const hasYear = fields.year.value.length > 0;
		const hasValidYear =
			!hasYear || (/^\d{4}$/.test(fields.year.value) && year >= 1000 && year <= currentYear);

		fields.year.classList.toggle('validator', hasYear);
		fields.year.setCustomValidity(hasValidYear ? '' : `Enter a year between 1000 and ${currentYear}`);
		updateSaveAlbumButton();
	};

	const updateAlbumPreview = () => {
		if (!albumPreviewInitial) return;

		albumPreviewInitial.textContent = fields.title?.value.trim().charAt(0).toUpperCase() ?? '';
	};

	const getAlbumMetadata = () => ({
		year: fields.year?.value ? Number(fields.year.value) : undefined,
		listened: fields.listened?.checked || undefined,
		rating: fields.listened?.checked && fields.ratingSlider?.value ? Number(fields.ratingSlider.value) : undefined,
		comment: fields.comment?.value.trim() || undefined,
		listened_at: fields.listened?.checked ? fields.listenedAt?.value || undefined : undefined,
	});

	const renderArtists = (artists: Artist[]) => {
		if (!fields.artist) return;

		const options = artists.map((artist) => new Option(artist.name, String(artist.id)));
		fields.artist.replaceChildren(new Option('Select artist', ''), ...options);
		updateSaveAlbumButton();
	};

	const resetCreateAlbumModal = () => {
		[fields.title, fields.artist, fields.year, fields.listenedAt, fields.comment].forEach((input) => {
			if (input) {
				input.value = '';
			}
		});

		if (fields.ratingSlider) {
			fields.ratingSlider.value = '5';
		}

		updateRatingMeasure();

		if (fields.listened) {
			fields.listened.checked = false;
		}

		updateListenedFields();
		updateAlbumPreview();
		errorAlert.hide();
		updateSaveAlbumButton();
	};

	saveAlbumButton?.addEventListener('click', async () => {
		const title = fields.title?.value.trim() ?? '';
		const artistId = Number(fields.artist?.value ?? 0);

		if (!title || !artistId) return;

		errorAlert.hide();
		setSavingAlbum(true);

		try {
			const album = await albumsApi.create({
				artist_id: artistId,
				title,
			});

			const albumMetadata = getAlbumMetadata();

			if (Object.values(albumMetadata).some((value) => value !== undefined)) {
				await albumsApi.update(album.id, {
					artist_id: artistId,
					...albumMetadata,
				});
			}

			await refreshDatabaseData();
			createModal?.close();
			resetCreateAlbumModal();
		} catch (error) {
			console.error('Failed to save album', error);
			errorAlert.showError(error, 'Failed to save album');
		} finally {
			setSavingAlbum(false);
		}
	});

	fields.title?.addEventListener('input', () => {
		updateAlbumPreview();
		updateSaveAlbumButton();
	});
	fields.artist?.addEventListener('change', updateSaveAlbumButton);
	fields.year?.addEventListener('input', updateYearValidity);
	fields.ratingSlider?.addEventListener('input', updateRatingMeasure);
	fields.listened?.addEventListener('change', updateListenedFields);
	manualAlbumTab?.addEventListener('change', updateSaveAlbumButton);
	spotifyAlbumTab?.addEventListener('change', updateSaveAlbumButton);

	fetchDatabaseData()
		.then(({ artists }) => renderArtists(artists))
		.catch((error) => {
			console.error('Failed to load artists', error);
			errorAlert.showError(error, 'Failed to load artists');
		});

	updateListenedFields();
	updateRatingMeasure();
	updateYearValidity();
	updateAlbumPreview();
	updateSaveAlbumButton();
</script>
