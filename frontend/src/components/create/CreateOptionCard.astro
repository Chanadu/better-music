---
interface Props {
	id: string;
	label: string;
}

const { id, label } = Astro.props;
---

<button
	type="button"
	id={id}
	class="group relative flex min-h-40 flex-col items-start justify-between overflow-hidden rounded-[1.8rem] border border-border/65 bg-linear-to-br from-surface via-surface-raised/75 to-surface p-5 text-left shadow-(--panel-shadow) transition-all duration-300 hover:-translate-y-1 hover:border-primary/35 hover:shadow-(--shell-shadow) active:scale-[0.98] sm:min-h-44 sm:p-6"
>
	<div class="absolute inset-0 bg-linear-to-br from-white/40 via-transparent to-transparent opacity-80 dark:from-white/4"></div>
	<div class="relative flex h-15 w-15 items-center justify-center rounded-[1.25rem] bg-primary/10 text-primary transition-transform duration-300 group-hover:scale-105 group-hover:bg-primary/16">
		<slot />
	</div>
	<div class="relative space-y-1">
		<p class="text-lg font-semibold tracking-tight text-text group-hover:text-primary">{label}</p>
		<p class="text-sm leading-6 text-text-muted">
			{label === 'Artist' ? 'Add a new artist to your library.' : 'Create an album and attach it to an artist.'}
		</p>
	</div>
	<div class="relative inline-flex items-center gap-2 text-sm font-semibold text-primary">
		<span>Open</span>
		<svg viewBox="0 0 24 24" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
			<path d="M5 12h14"></path>
			<path d="m13 6 6 6-6 6"></path>
		</svg>
	</div>
</button>
