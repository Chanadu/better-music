---
import ModalHeader from '../ui/ModalHeader.astro';
import BaseDialog from '../ui/BaseDialog.astro';
import CoverPreviewField from '../ui/CoverPreviewField.astro';
import DialogTabSwitcher from '../ui/DialogTabSwitcher.astro';
import FloatingInput from '../ui/FloatingInput.astro';
import SpotifySearchPanel from '../ui/SpotifySearchPanel.astro';
import { BUTTON_PRIMARY_CLASS } from '../../lib/button-styles';
---

<BaseDialog
	id='artist-modal'
	className='border-border bg-surface text-text m-auto w-[min(92vw,32rem)] rounded-2xl border p-0 shadow-2xl backdrop:bg-black/50'
	contentClassName='p-5 sm:p-6'
	mobilePlacement='center'
>
	<ModalHeader title='Create Artist' />

	<DialogTabSwitcher
		manualButtonId='artist-tab-manual'
		spotifyButtonId='artist-tab-spotify'
		activeTab='spotify'
		className='mt-4'
	/>

	<!-- Manual Tab -->
	<form id='artist-form' class='mt-4 hidden space-y-4'>
		<FloatingInput id='artist-name' name='name' label='Name' required />
		<CoverPreviewField
			inputId='artist-cover-url'
			name='cover_url'
			imageId='artist-cover-preview'
			emptyId='artist-cover-empty'
			label='Cover Art'
			emptyLabel='Use Spotify search to add cover art'
			imageAlt='Artist cover preview'
		/>

		<p id='artist-form-status' class='text-text-muted text-sm' role='alert' aria-live='assertive'></p>

		<button
			type='submit'
			id='artist-create-btn'
			class:list={[BUTTON_PRIMARY_CLASS, 'mx-auto mt-4 w-full cursor-pointer disabled:cursor-not-allowed sm:w-auto']}
		>
			Create Artist
		</button>
	</form>

	<SpotifySearchPanel
		panelId='artist-spotify-tab'
		searchInputId='artist-spotify-search'
		spinnerId='artist-spotify-spinner'
		resultsId='artist-spotify-results'
		warningId='artist-spotify-offline-warning'
		searchLabel='Search Spotify Artists'
		hint='Select an artist to auto-fill the form'
		offlineMessage='Spotify search is unavailable offline. Switch to Manual to create an artist without reconnecting.'
		className='mt-4'
	/>
</BaseDialog>

<script>
	import { syncCoverPreview } from '../../lib/cover-preview';
	import { closeDialogSafely, openDialogSafely, toggleDialogTabs } from '../../lib/dialog';
	import { bindOnce } from '../../lib/events';
	import { createArtistRecord } from '../../lib/library-cache';
	import { searchArtists, type SpotifyArtist } from '../../lib/spotify';
	import {
		bindSpotifySearch,
		getSpotifySearchElements,
		isNavigatorOnline,
		resetSpotifySearch,
		syncSpotifySearchAvailability,
	} from '../../lib/spotify-search';
	import { setInlineStatus } from '../../lib/status';

	const getArtistModal = () => document.getElementById('artist-modal') as HTMLDialogElement | null;
	const getArtistForm = () => document.getElementById('artist-form') as HTMLFormElement | null;
	const getArtistNameInput = () => document.getElementById('artist-name') as HTMLInputElement | null;
	const getArtistCoverURLInput = () => document.getElementById('artist-cover-url') as HTMLInputElement | null;
	const getArtistCoverPreview = () => document.getElementById('artist-cover-preview') as HTMLImageElement | null;
	const getArtistCoverEmptyState = () => document.getElementById('artist-cover-empty') as HTMLParagraphElement | null;
	const getArtistFormStatus = () => document.getElementById('artist-form-status') as HTMLParagraphElement | null;
	const getArtistCreateBtn = () => document.getElementById('artist-create-btn') as HTMLButtonElement | null;
	const getArtistSpotifyElements = () =>
		getSpotifySearchElements({
			inputId: 'artist-spotify-search',
			spinnerId: 'artist-spotify-spinner',
			resultsId: 'artist-spotify-results',
			warningId: 'artist-spotify-offline-warning',
		});
	const isOnline = isNavigatorOnline;

	const openModal = () => {
		openDialogSafely(getArtistModal());
	};

	const closeModal = () => {
		closeDialogSafely(getArtistModal());
	};

	const switchTab = (tab: 'manual' | 'spotify') => {
		toggleDialogTabs(tab, {
			manualPanel: getArtistForm(),
			spotifyPanel: document.getElementById('artist-spotify-tab'),
			manualButton: document.getElementById('artist-tab-manual'),
			spotifyButton: document.getElementById('artist-tab-spotify'),
			searchInput: getArtistSpotifyElements().input,
		});
	};

	const setArtistCover = (url: string | null | undefined) => {
		syncCoverPreview(getArtistCoverURLInput(), getArtistCoverPreview(), getArtistCoverEmptyState(), url);
	};

	const syncArtistSpotifyAvailability = () => {
		syncSpotifySearchAvailability(getArtistSpotifyElements(), { isOnline });
	};

	const resetArtistSpotifySearch = () => {
		resetSpotifySearch(getArtistSpotifyElements());
	};

	let selectedSpotifyArtistID: string | null = null;

	const applySpotifyArtist = (artist: SpotifyArtist) => {
		const nameInput = getArtistNameInput();
		const selectedImage = artist.images[0]?.url ?? artist.images[artist.images.length - 1]?.url ?? '';
		selectedSpotifyArtistID = artist.id;
		if (nameInput) nameInput.value = artist.name;
		setArtistCover(selectedImage);
		resetArtistSpotifySearch();
		switchTab('manual');
	};

	const renderArtistResult = (artist: SpotifyArtist) => {
		const img = artist.images[artist.images.length - 1];
		const item = document.createElement('li');
		item.className =
			'ui-subtle-pressable border-border/30 flex cursor-pointer items-center gap-3 border-b px-4 py-3 text-sm font-medium text-text transition-colors hover:bg-surface-raised last:border-0';
		item.innerHTML = `
			${img ? `<img src="${img.url}" alt="" class="h-10 w-10 shrink-0 rounded-full border border-border/40 object-cover" />` : '<div class="bg-surface-raised flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-border/40 text-xs text-text-muted">?</div>'}
			<span class="truncate">${artist.name}</span>
			<span class="text-secondary ml-auto shrink-0 text-xs font-medium">Select →</span>
		`;
		item.addEventListener('click', () => applySpotifyArtist(artist));
		return item;
	};

	const bindArtistSpotifySearch = () => {
		bindSpotifySearch({
			elements: getArtistSpotifyElements(),
			search: searchArtists,
			renderResult: renderArtistResult,
			isOnline,
		});
	};

	const bindArtistTabButtons = () => {
		const manualButton = document.getElementById('artist-tab-manual') as HTMLButtonElement | null;
		const spotifyButton = document.getElementById('artist-tab-spotify') as HTMLButtonElement | null;

		if (manualButton && manualButton.dataset.bound !== 'true') {
			manualButton.dataset.bound = 'true';
			manualButton.addEventListener('click', () => switchTab('manual'));
		}

		if (spotifyButton && spotifyButton.dataset.bound !== 'true') {
			spotifyButton.dataset.bound = 'true';
			spotifyButton.addEventListener('click', () => {
				syncArtistSpotifyAvailability();
				switchTab('spotify');
			});
		}
	};

	const bindArtistModalDismiss = () => {
		const modal = getArtistModal();
		if (!modal || modal.dataset.dismissBound === 'true') return;
		modal.dataset.dismissBound = 'true';
		modal.addEventListener('click', (event) => {
			if (event.target === modal) closeModal();
		});
	};

	const bindArtistFormSubmit = () => {
		const form = getArtistForm();
		if (!form || form.dataset.bound === 'true') return;
		form.dataset.bound = 'true';

		form.addEventListener('submit', async (event) => {
			event.preventDefault();

			const artistNameInput = getArtistNameInput();
			const artistCoverURLInput = getArtistCoverURLInput();
			const artistFormStatus = getArtistFormStatus();
			const artistCreateBtn = getArtistCreateBtn();
			if (!artistNameInput) return;

			const name = artistNameInput.value.trim();
			const coverURL = artistCoverURLInput?.value.trim() ?? '';

			if (!name) {
				switchTab('manual');
				setInlineStatus(artistFormStatus, 'Artist name is required.', 'error');
				return;
			}

			if (artistCreateBtn) {
				artistCreateBtn.disabled = true;
				artistCreateBtn.textContent = 'Creating...';
			}

			setInlineStatus(artistFormStatus, isOnline() ? 'Saving artist...' : 'Saving artist offline...');

			try {
				const result = await createArtistRecord({
					name,
					...(selectedSpotifyArtistID ? { spotify_id: selectedSpotifyArtistID } : {}),
					...(coverURL ? { cover_url: coverURL } : {}),
				});

				setInlineStatus(
					artistFormStatus,
					result.syncStatus === 'synced' ?
						'Artist created successfully.'
					:	'Artist saved offline. It will sync when you reconnect.',
					'success',
				);
				form.reset();
				selectedSpotifyArtistID = null;
				setArtistCover('');
				resetArtistSpotifySearch();
				setTimeout(() => closeModal(), 400);
			} catch (error) {
				switchTab('manual');
				setInlineStatus(
					artistFormStatus,
					error instanceof Error ? error.message : 'Failed to save artist.',
					'error',
				);
			} finally {
				if (artistCreateBtn) {
					artistCreateBtn.disabled = false;
					artistCreateBtn.textContent = 'Create Artist';
				}
			}
		});
	};

	const initializeArtistModal = () => {
		bindArtistModalDismiss();
		bindArtistTabButtons();
		bindArtistSpotifySearch();
		bindArtistFormSubmit();
		syncArtistSpotifyAvailability();
	};

	bindOnce('__openArtistModalBound', () => {
		window.addEventListener('open-artist-modal', () => {
			requestAnimationFrame(() => {
				initializeArtistModal();
				getArtistForm()?.reset();
				openModal();
				selectedSpotifyArtistID = null;
				setArtistCover('');
				resetArtistSpotifySearch();
				setInlineStatus(getArtistFormStatus(), '');
				switchTab('spotify');
			});
		});
	});

	bindOnce('__artistSpotifyAvailabilityBound', () => {
		window.addEventListener('online', syncArtistSpotifyAvailability);
		window.addEventListener('offline', syncArtistSpotifyAvailability);
		document.addEventListener('astro:page-load', initializeArtistModal);
	});

	initializeArtistModal();
</script>
