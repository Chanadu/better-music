---
import BaseDialog from '../ui/BaseDialog.astro';
import CoverPreviewField from '../ui/CoverPreviewField.astro';
import DialogTabSwitcher from '../ui/DialogTabSwitcher.astro';
import FilterSelect from '../ui/FilterSelect.astro';
import FloatingInput from '../ui/FloatingInput.astro';
import InteractiveListToolkit from '../ui/InteractiveListToolkit.astro';
import SearchField from '../ui/SearchField.astro';
import SpotifyRefreshButton from '../ui/SpotifyRefreshButton.astro';
import SpotifySearchPanel from '../ui/SpotifySearchPanel.astro';
import SortControls from '../ui/SortControls.astro';
import SyncStatusBanner from '../ui/SyncStatusBanner.astro';
import { BUTTON_PRIMARY_CLASS } from '../../lib/button-styles';
---

<section data-artist-directory-root='true'>
	<div class='mb-3'>
		<SearchField
			inputId='artists-search'
			label='Search artists'
			placeholder='Search artists or album titles'
			wrapperClassName='min-w-0'
			data-artists-search='true'
		/>
	</div>
	<div class='mb-4 flex items-center gap-2 sm:mx-auto sm:w-fit sm:max-w-full sm:justify-center sm:gap-3'>
		<FilterSelect
			selectId='artists-albums-filter'
			label='Filter'
			wrapperClassName='min-w-0 flex-1 sm:flex-none sm:grid-cols-[auto_12rem]'
			data-artists-albums-filter='true'
		>
			<option value='all'>All artists</option>
			<option value='withAlbums'>With albums</option>
			<option value='withoutAlbums'>No albums</option>
		</FilterSelect>
		<SortControls
			controlId='artists-sort-by'
			containerClass='grid min-w-0 flex-1 grid-cols-[minmax(0,1fr)_auto] items-center gap-1.5 sm:w-auto sm:max-w-full sm:flex-none sm:shrink-0 sm:grid-cols-[auto_auto_auto] sm:gap-3'
		/>
	</div>

	<SyncStatusBanner bannerId='artists-sync-banner' textId='artists-sync-banner-text' className='mb-4' />

	<div id='artists-list' class='space-y-3'></div>
</section>

<InteractiveListToolkit />

<BaseDialog
	id='edit-artist-modal'
	className='border-border bg-surface text-text m-auto w-[min(92vw,32rem)] rounded-2xl border p-0 shadow-2xl backdrop:bg-black/45'
	contentClassName=''
	mobilePlacement='center'
>
	<form id='edit-artist-form' class='space-y-3 p-5'>
		<div class='flex items-center justify-between'>
			<h3 class='text-lg font-semibold'>Edit Artist</h3>
		</div>
		<input id='edit-artist-id' type='hidden' />
		<DialogTabSwitcher manualButtonId='edit-artist-tab-manual' spotifyButtonId='edit-artist-tab-spotify' />
		<div id='edit-artist-manual-panel' class='space-y-3'>
			<FloatingInput id='edit-artist-name' label='Name' required />
			<CoverPreviewField
				inputId='edit-artist-cover-url'
				imageId='edit-artist-cover-preview'
				emptyId='edit-artist-cover-empty'
				label='Cover Art'
				emptyLabel='No cover image available'
				imageAlt='Artist cover preview'
			/>
			<SpotifyRefreshButton buttonId='edit-artist-spotify-refresh-btn' />
		</div>
		<SpotifySearchPanel
			panelId='edit-artist-spotify-panel'
			searchInputId='edit-artist-spotify-search'
			spinnerId='edit-artist-spotify-spinner'
			resultsId='edit-artist-spotify-results'
			warningId='edit-artist-spotify-offline-warning'
			searchLabel='Search Spotify Artists'
			hint='Select a Spotify artist to replace the saved metadata for this entry.'
			offlineMessage='Spotify search is unavailable offline. Switch back to Manual to keep editing without reconnecting.'
			className='hidden'
		/>
		<p id='edit-artist-status' class='text-text-muted text-sm'></p>
		<div class='flex flex-col-reverse gap-3 pt-2 sm:flex-row sm:items-center sm:justify-center sm:pt-0'>
			<button
				type='submit'
				id='edit-artist-submit'
				class:list={[BUTTON_PRIMARY_CLASS, 'w-full sm:w-auto']}
				>Save Artist</button
			>
		</div>
	</form>
</BaseDialog>

<script>
	import { syncCoverPreview } from '../../lib/cover-preview';
	import { formatDateTime } from '../../lib/date';
	import { toggleDialogTabs } from '../../lib/dialog';
	import { createEmptyState } from '../../lib/empty-state';
	import { bindOnce } from '../../lib/events';
	import {
		deleteArtistRecord,
		hasCachedLibraryData,
		loadLibraryData,
		updateArtistRecord,
	} from '../../lib/library-cache';
	import { hidePageLoadingSkeleton, showPageLoadingSkeleton } from '../../lib/page-skeletons';
	import { getArtistBySpotifyID, searchArtists, type SpotifyArtist } from '../../lib/spotify';
	import {
		bindSpotifySearch,
		getSpotifySearchElements,
		isNavigatorOnline,
		resetSpotifySearch,
		syncSpotifySearchAvailability,
	} from '../../lib/spotify-search';
	import { initializeSortControls, type SortDirection } from '../../lib/sort';
	import { ICON_PATHS, applyRatingTone, createArtistChip } from '../../lib/ui';

	type EntitySyncState = 'synced' | 'pending';

	type Artist = {
		id: number;
		name: string;
		cover_url?: string | null;
		spotify_id?: string | null;
		created_at: string;
		local_only?: boolean;
		sync_state?: EntitySyncState;
	};

	type Album = {
		id: number;
		artist_id: number;
		title: string;
		listened: boolean;
		rating?: number | null;
		year?: number | null;
		comment?: string | null;
		listened_at?: string | null;
		created_at: string;
		local_only?: boolean;
		sync_state?: EntitySyncState;
	};

	type StatusType = 'neutral' | 'error' | 'success';
	type ArtistSortKey = 'alphabetical' | 'createdAt' | 'averageRating';
	type ArtistAlbumFilter = 'all' | 'withAlbums' | 'withoutAlbums';

	type InteractiveCardOptions = {
		onEdit: () => void;
		onDelete: () => void;
		editLabel: string;
		deleteLabel: string;
		toggleLabel: string;
		enableSwipe?: boolean;
	};

	type InteractiveCardParts = {
		wrapper: HTMLDivElement;
		left: HTMLDivElement;
		right: HTMLDivElement;
		setBody: (body: HTMLElement) => void;
	};

	type InteractiveListToolkitAPI = {
		setListRootMessage: (listRoot: HTMLDivElement | null, message: string, isError?: boolean) => void;
		setStatusText: (target: HTMLElement | null, message: string, type?: StatusType) => void;
		showDialogSafely: (dialog: HTMLDialogElement | null) => void;
		createInteractiveListCard: (options: InteractiveCardOptions) => InteractiveCardParts;
	};

	const getToolkitInstance = () =>
		(window as Window & { __interactiveListToolkit?: InteractiveListToolkitAPI }).__interactiveListToolkit ?? null;

	const getToolkit = () => {
		const toolkit = getToolkitInstance();
		if (!toolkit) throw new Error('Interactive list toolkit unavailable');
		return toolkit;
	};

	const getComponentRoot = () => document.querySelector('[data-artist-directory-root="true"]') as HTMLElement | null;
	const getListRoot = () => document.getElementById('artists-list') as HTMLDivElement | null;
	const getSearchInput = () =>
		getComponentRoot()?.querySelector('[data-artists-search="true"]') as HTMLInputElement | null;
	const getAlbumsFilterInput = () =>
		getComponentRoot()?.querySelector('[data-artists-albums-filter="true"]') as HTMLSelectElement | null;
	const getSyncBanner = () => document.getElementById('artists-sync-banner') as HTMLDivElement | null;
	const getSyncBannerText = () => document.getElementById('artists-sync-banner-text') as HTMLParagraphElement | null;
	const getEditArtistSpotifyElements = () =>
		getSpotifySearchElements({
			inputId: 'edit-artist-spotify-search',
			spinnerId: 'edit-artist-spotify-spinner',
			resultsId: 'edit-artist-spotify-results',
			warningId: 'edit-artist-spotify-offline-warning',
		});
	const isOnline = isNavigatorOnline;
	let editArtistDialog: HTMLDialogElement | null = null;
	let editArtistForm: HTMLFormElement | null = null;
	let editArtistIDInput: HTMLInputElement | null = null;
	let editArtistNameInput: HTMLInputElement | null = null;
	let editArtistCoverURLInput: HTMLInputElement | null = null;
	let editArtistStatus: HTMLParagraphElement | null = null;
	let editArtistSubmit: HTMLButtonElement | null = null;
	let currentArtistAlbumCount = 0;
	let currentEditArtistSpotifyID: string | null = null;
	let currentSortBy: ArtistSortKey = 'alphabetical';
	let currentSortDirection: SortDirection = 'asc';
	let currentSearchQuery = '';
	let currentAlbumFilter: ArtistAlbumFilter = 'all';
	let toolkitRetryCount = 0;
	let lastLoadedArtists: Artist[] = [];
	let lastLoadedAlbums: Album[] = [];
	const MAX_TOOLKIT_RETRIES = 18;

	const getNormalizedSearchQuery = () => currentSearchQuery.trim().toLocaleLowerCase();
	const hasPendingSync = (entity: { local_only?: boolean; sync_state?: EntitySyncState | null }) =>
		Boolean(entity.local_only) || entity.sync_state === 'pending';
	const syncThemedFilterSelect = (select: HTMLSelectElement | null) => {
		select?.dispatchEvent(new Event('themed-select-sync'));
	};

	const refreshEditRefs = () => {
		editArtistDialog = document.getElementById('edit-artist-modal') as HTMLDialogElement | null;
		editArtistForm = document.getElementById('edit-artist-form') as HTMLFormElement | null;
		editArtistIDInput = document.getElementById('edit-artist-id') as HTMLInputElement | null;
		editArtistNameInput = document.getElementById('edit-artist-name') as HTMLInputElement | null;
		editArtistCoverURLInput = document.getElementById('edit-artist-cover-url') as HTMLInputElement | null;
		editArtistStatus = document.getElementById('edit-artist-status') as HTMLParagraphElement | null;
		editArtistSubmit = document.getElementById('edit-artist-submit') as HTMLButtonElement | null;
	};

	const setEditArtistCover = (url: string | null | undefined) => {
		syncCoverPreview(
			editArtistCoverURLInput,
			document.getElementById('edit-artist-cover-preview') as HTMLImageElement | null,
			document.getElementById('edit-artist-cover-empty') as HTMLParagraphElement | null,
			url,
		);
	};

	const switchEditArtistTab = (tab: 'manual' | 'spotify') => {
		toggleDialogTabs(tab, {
			manualPanel: document.getElementById('edit-artist-manual-panel'),
			spotifyPanel: document.getElementById('edit-artist-spotify-panel'),
			manualButton: document.getElementById('edit-artist-tab-manual'),
			spotifyButton: document.getElementById('edit-artist-tab-spotify'),
			searchInput: getEditArtistSpotifyElements().input,
		});
	};

	const resetEditArtistSpotifySearch = () => {
		resetSpotifySearch(getEditArtistSpotifyElements());
	};

	const syncEditArtistSpotifyAvailability = () => {
		syncSpotifySearchAvailability(getEditArtistSpotifyElements(), { isOnline });
	};

	const hasPendingArtistGroup = (artist: Artist, albums: Album[]) =>
		hasPendingSync(artist) || albums.some((album) => hasPendingSync(album));

	const syncArtistBanner = (artists = lastLoadedArtists, albums = lastLoadedAlbums) => {
		const banner = getSyncBanner();
		const text = getSyncBannerText();
		if (!banner || !text) return;

		const pendingCount =
			artists.filter((artist) => hasPendingSync(artist)).length +
			albums.filter((album) => hasPendingSync(album)).length;

		if (pendingCount === 0) {
			banner.classList.add('hidden');
			text.textContent = '';
			return;
		}

		banner.classList.remove('hidden');
		text.textContent =
			isOnline() ?
				`${pendingCount} change${pendingCount === 1 ? '' : 's'} pending sync. The app will keep retrying automatically.`
			:	`${pendingCount} change${pendingCount === 1 ? '' : 's'} saved offline. They will sync when you reconnect.`;
	};

	const resetArtistFilters = () => {
		currentSearchQuery = '';
		currentAlbumFilter = 'all';

		const searchInput = getSearchInput();
		if (searchInput) searchInput.value = '';
		const albumsFilterInput = getAlbumsFilterInput();
		if (albumsFilterInput) {
			albumsFilterInput.value = 'all';
			syncThemedFilterSelect(albumsFilterInput);
		}
	};

	const sortAlbums = (albums: Album[]): Album[] => {
		return [...albums].sort((a, b) => {
			if (a.listened !== b.listened) return a.listened ? -1 : 1;
			const aRating = a.rating ?? -1;
			const bRating = b.rating ?? -1;
			if (aRating !== bRating) return bRating - aRating;
			return a.title.localeCompare(b.title);
		});
	};

	const getAverageArtistRating = (albums: Album[]) => {
		const rated = albums.filter((album) => album.listened && album.rating != null);
		if (!rated.length) return null;
		return rated.reduce((sum, album) => sum + Number(album.rating ?? 0), 0) / rated.length;
	};

	const compareOptionalNumber = (a: number | null, b: number | null) => {
		if (a == null && b == null) return 0;
		if (a == null) return 1;
		if (b == null) return -1;
		return a - b;
	};

	const syncArtistSortControls = () => {
		const options: Array<{ value: ArtistSortKey; label: string }> = [
			{ value: 'alphabetical', label: 'Alphabetical' },
			{ value: 'createdAt', label: 'Creation Date' },
			{ value: 'averageRating', label: 'Average Rating' },
		];

		initializeSortControls({
			controlPrefix: 'artists-sort',
			options,
			getSortBy: () => currentSortBy,
			setSortBy: (value) => {
				currentSortBy = value;
			},
			getSortDirection: () => currentSortDirection,
			setSortDirection: (value) => {
				currentSortDirection = value;
			},
			onChange: () => void loadArtists(),
		});
	};

	const resetSortControls = () => {
		currentSortBy = 'alphabetical';
		currentSortDirection = 'asc';
	};

	const setMessage = (message: string, isError = false) =>
		getToolkit().setListRootMessage(getListRoot(), message, isError);

	const renderEmptyArtistsState = () => {
		const listRoot = getListRoot();
		if (!listRoot) return;
		listRoot.replaceChildren(
			createEmptyState({
				title: 'No artists yet',
				description: 'Add your first artist to start building the library.',
				buttonLabel: 'Create Artist',
				onClick: () => window.dispatchEvent(new CustomEvent('open-artist-modal')),
			}),
		);
	};

	const clearArtistSearch = () => {
		currentSearchQuery = '';
		const searchInput = getSearchInput();
		if (searchInput) searchInput.value = '';
	};

	const renderArtistSearchEmptyState = () => {
		const listRoot = getListRoot();
		if (!listRoot) return;

		listRoot.replaceChildren(
			createEmptyState({
				title: 'No matching artists',
				description: 'Nothing matched the current search and filters. Adjust them or reset to see your full library again.',
				buttonLabel: 'Reset Filters',
				onClick: () => {
					resetArtistFilters();
					void loadArtists();
				},
			}),
		);
	};

	const setEditStatus = (message: string, type: 'neutral' | 'error' | 'success' = 'neutral') => {
		getToolkit().setStatusText(editArtistStatus, message, type);
	};

	const applySpotifyArtistToEditForm = (artist: SpotifyArtist, options: { switchToManual?: boolean } = {}) => {
		if (!editArtistNameInput) return;
		const selectedImage = artist.images[0]?.url ?? artist.images[artist.images.length - 1]?.url ?? '';
		currentEditArtistSpotifyID = artist.id;
		editArtistNameInput.value = artist.name;
		setEditArtistCover(selectedImage);
		resetEditArtistSpotifySearch();
		if (options.switchToManual ?? true) switchEditArtistTab('manual');
		setEditStatus('Spotify metadata applied. Review and save.', 'success');
	};

	const renderEditArtistResult = (artist: SpotifyArtist) => {
		const img = artist.images[artist.images.length - 1];
		const item = document.createElement('li');
		item.className =
			'ui-subtle-pressable border-border/30 flex cursor-pointer items-center gap-3 border-b px-4 py-3 text-sm font-medium text-text transition-colors hover:bg-surface-raised last:border-0';
		item.innerHTML = `
			${img ? `<img src="${img.url}" alt="" class="h-10 w-10 shrink-0 rounded-full border border-border/40 object-cover" />` : '<div class="bg-surface-raised flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-border/40 text-xs text-text-muted">?</div>'}
			<span class="truncate">${artist.name}</span>
			<span class="text-secondary ml-auto shrink-0 text-xs font-medium">Select →</span>
		`;
		item.addEventListener('click', () => applySpotifyArtistToEditForm(artist));
		return item;
	};

	const bindEditArtistSpotifySearch = () => {
		bindSpotifySearch({
			elements: getEditArtistSpotifyElements(),
			search: searchArtists,
			renderResult: renderEditArtistResult,
			isOnline,
		});
	};

	const showDialogSafely = (dialog: HTMLDialogElement | null) => {
		getToolkit().showDialogSafely(dialog);
	};

	const deleteArtist = async (id: number, name: string, albumCount: number) => {
		if (albumCount > 0) {
			window.alert(`Cannot delete "${name}" because they have ${albumCount} album(s). Delete the albums first.`);
			return;
		}
		if (!window.confirm(`Delete "${name}"? This cannot be undone.`)) return;
		try {
			await deleteArtistRecord(id);
			editArtistDialog?.close();
		} catch {
			window.alert('Failed to delete artist.');
		}
	};

	const openEditDialog = (artist: Artist, albumCount: number) => {
		refreshEditRefs();
		if (!editArtistDialog || !editArtistIDInput || !editArtistNameInput || !editArtistCoverURLInput) return;
		editArtistIDInput.value = String(artist.id);
		editArtistNameInput.value = artist.name;
		setEditArtistCover(artist.cover_url);
		currentEditArtistSpotifyID = artist.spotify_id ?? null;
		currentArtistAlbumCount = albumCount;
		resetEditArtistSpotifySearch();
		switchEditArtistTab('manual');
		syncEditArtistSpotifyAvailability();
		setEditStatus('');
		showDialogSafely(editArtistDialog);
	};

	const bindEditHandlers = () => {
		refreshEditRefs();
		if (!editArtistForm || editArtistForm.dataset.bound === 'true') return;
		editArtistForm.dataset.bound = 'true';

		editArtistDialog?.addEventListener('click', (event) => {
			if (editArtistDialog && event.target === editArtistDialog) editArtistDialog.close();
		});
		document
			.getElementById('edit-artist-tab-manual')
			?.addEventListener('click', () => switchEditArtistTab('manual'));
		document.getElementById('edit-artist-tab-spotify')?.addEventListener('click', () => {
			syncEditArtistSpotifyAvailability();
			switchEditArtistTab('spotify');
		});
		bindEditArtistSpotifySearch();

		const refreshSpotifyButton = document.getElementById(
			'edit-artist-spotify-refresh-btn',
		) as HTMLButtonElement | null;
		refreshSpotifyButton?.addEventListener('click', async () => {
			if (!editArtistNameInput || !editArtistCoverURLInput) return;
			if (!currentEditArtistSpotifyID) {
				setEditStatus('This artist does not have a saved Spotify match to refresh.', 'error');
				return;
			}

			refreshSpotifyButton.disabled = true;
			refreshSpotifyButton.textContent = 'Refreshing...';
			setEditStatus('Refreshing from Spotify...');

			try {
				const artist = await getArtistBySpotifyID(currentEditArtistSpotifyID);
				applySpotifyArtistToEditForm(artist, { switchToManual: false });
			} catch {
				setEditStatus('Failed to refresh from Spotify.', 'error');
			} finally {
				refreshSpotifyButton.disabled = false;
				refreshSpotifyButton.textContent = 'Refresh from Spotify';
			}
		});

		editArtistForm.addEventListener('submit', async (event) => {
			event.preventDefault();
			if (!editArtistIDInput || !editArtistNameInput || !editArtistCoverURLInput || !editArtistSubmit) return;
			editArtistSubmit.disabled = true;
			editArtistSubmit.textContent = 'Saving...';
			setEditStatus('Saving artist...');
			try {
				const result = await updateArtistRecord(Number(editArtistIDInput.value), {
					name: editArtistNameInput.value.trim(),
					...(currentEditArtistSpotifyID ? { spotify_id: currentEditArtistSpotifyID } : {}),
					...(editArtistCoverURLInput.value.trim() ?
						{ cover_url: editArtistCoverURLInput.value.trim() }
					:	{}),
				});
				setEditStatus(
					result.syncStatus === 'synced' ?
						'Artist updated successfully.'
					:	'Artist updated offline. It will sync when you reconnect.',
					'success',
				);
				editArtistSubmit.disabled = false;
				editArtistSubmit.textContent = 'Save Artist';
				setTimeout(() => editArtistDialog?.close(), 250);
				return;
			} catch {
				setEditStatus('Failed to update artist.', 'error');
				editArtistSubmit.disabled = false;
				editArtistSubmit.textContent = 'Save Artist';
				return;
			}
		});
	};

	const renderArtistCard = (artist: Artist, albums: Album[]) => {
		const groupHasPendingSync = hasPendingArtistGroup(artist, albums);
		const card = getToolkit().createInteractiveListCard({
			onEdit: () => openEditDialog(artist, albums.length),
			onDelete: () => void deleteArtist(artist.id, artist.name, albums.length),
			editLabel: 'Edit artist',
			deleteLabel: 'Delete artist',
			toggleLabel: 'Toggle artist details',
		});
		const { wrapper, left, setBody } = card;

		if (artist.cover_url) {
			const coverWrap = document.createElement('div');
			coverWrap.className = 'relative shrink-0 overflow-hidden rounded-full border border-border/40 shadow-sm';
			const cover = document.createElement('img');
			cover.src = artist.cover_url;
			cover.alt = `${artist.name} cover`;
			cover.className = 'h-12 w-12 object-cover sm:h-14 sm:w-14';
			coverWrap.appendChild(cover);
			left.appendChild(coverWrap);
		}

		const headerContent = document.createElement('div');
		headerContent.className = 'min-w-0 flex-1';
		const name = document.createElement('h3');
		name.className = 'truncate text-base font-bold text-text sm:text-lg';
		name.textContent = artist.name;
		headerContent.appendChild(name);
		const averageRatingValue = getAverageArtistRating(albums);
		const averageRating = averageRatingValue == null ? null : averageRatingValue.toFixed(1);
		const meta = document.createElement('div');
		meta.className = 'mt-0.5 text-sm text-text-muted';
		meta.textContent = `${albums.length} album${albums.length === 1 ? '' : 's'}${averageRating ? ` • Avg ${averageRating}/10` : ''}`;
		headerContent.appendChild(meta);
		if (groupHasPendingSync) {
			const syncChip = createArtistChip(
				isOnline() ? 'Pending Sync' : 'Saved Offline',
				ICON_PATHS.syncPending,
				'primary',
			);
			syncChip.classList.add('mt-2');
			headerContent.appendChild(syncChip);
		}
		left.appendChild(headerContent);

		const body = document.createElement('div');
		body.className = 'border-t border-border/30 bg-surface-raised/50 p-4 sm:p-5';
		const created = document.createElement('p');
		created.className = 'mb-4 text-sm text-text-muted';
		created.textContent = `Added: ${formatDateTime(artist.created_at)}`;
		body.appendChild(created);
		const title = document.createElement('h4');
		title.className = 'mb-3 text-sm font-semibold text-text uppercase tracking-wider';
		title.textContent = 'Albums';
		body.appendChild(title);

		if (albums.length === 0) {
			const empty = document.createElement('p');
			empty.className = 'text-sm text-text-muted italic';
			empty.textContent = 'No albums yet.';
			body.appendChild(empty);
		} else {
			const list = document.createElement('ul');
			list.className = 'flex flex-col';
			for (const album of sortAlbums(albums)) {
				const item = document.createElement('li');
				item.className =
					'flex items-center justify-between gap-2 border-b border-border/20 px-3 py-2 last:border-0';
				const left = document.createElement('div');
				left.className = 'min-w-0 flex-1';
				const albumTitle = document.createElement('p');
				albumTitle.className = 'truncate text-sm font-medium text-text';
				albumTitle.textContent = album.title;
				const albumMeta = document.createElement('p');
				albumMeta.className = 'text-[11px] text-text-muted';
				left.appendChild(albumTitle);
				if (album.year != null) {
					albumMeta.textContent = String(album.year);
					left.appendChild(albumMeta);
				}

				const rightPills = document.createElement('div');
				rightPills.className = 'flex shrink-0 items-center gap-1.5';
				if (hasPendingSync(album)) {
					rightPills.appendChild(createArtistChip('Pending', ICON_PATHS.syncPending, 'primary'));
				}
				if (!album.listened)
					rightPills.appendChild(createArtistChip('New', ICON_PATHS.newSparkle, 'secondary'));
				if (album.listened && album.rating != null) {
					const ratingChip = createArtistChip(`${album.rating}/10`, ICON_PATHS.ratingStar, 'neutral');
					applyRatingTone(ratingChip, Number(album.rating), '--surface');
					rightPills.appendChild(ratingChip);
				}
				item.appendChild(left);
				item.appendChild(rightPills);
				list.appendChild(item);
			}
			body.appendChild(list);
		}

		setBody(body);
		return wrapper;
	};

	const matchesArtistSearch = (artist: Artist, albums: Album[]) => {
		const query = getNormalizedSearchQuery();
		if (!query) return true;

		const artistMatches = artist.name.toLocaleLowerCase().includes(query);
		if (artistMatches) return true;

		return albums.some((album) =>
			[album.title, album.year == null ? '' : String(album.year), album.comment ?? ''].some((value) =>
				value.toLocaleLowerCase().includes(query),
			),
		);
	};

	const matchesArtistFilters = (artist: Artist, albums: Album[]) => {
		if (currentAlbumFilter === 'withAlbums' && albums.length === 0) return false;
		if (currentAlbumFilter === 'withoutAlbums' && albums.length > 0) return false;
		return true;
	};

	const bindSearchHandlers = () => {
		const searchInput = getSearchInput();
		if (!searchInput || searchInput.dataset.bound === 'true') return;

		searchInput.dataset.bound = 'true';
		searchInput.value = currentSearchQuery;
		searchInput.addEventListener('input', () => {
			currentSearchQuery = searchInput.value;
			void loadArtists();
		});
		searchInput.addEventListener('search', () => {
			currentSearchQuery = searchInput.value;
			void loadArtists();
		});
	};

	const bindFilterHandlers = () => {
		const albumsFilterInput = getAlbumsFilterInput();
		if (albumsFilterInput) {
			albumsFilterInput.value = currentAlbumFilter;
			syncThemedFilterSelect(albumsFilterInput);
		}
		if (albumsFilterInput && albumsFilterInput.dataset.bound !== 'true') {
			albumsFilterInput.dataset.bound = 'true';
			albumsFilterInput.addEventListener('change', () => {
				currentAlbumFilter = albumsFilterInput.value as ArtistAlbumFilter;
				void loadArtists();
			});
		}
	};

	const loadArtists = async () => {
		const listRoot = getListRoot();
		if (!listRoot) return;
		const route = '/artists';
		const shouldShowSkeleton = !hasCachedLibraryData();
		if (shouldShowSkeleton) showPageLoadingSkeleton(route);
		syncArtistSortControls();
		listRoot.innerHTML = '';
		try {
			const { artists, albums } = await loadLibraryData();
			const artistData = artists as Artist[];
			const albumData = albums as Album[];
			lastLoadedArtists = artistData;
			lastLoadedAlbums = albumData;
			syncArtistBanner();
			listRoot.innerHTML = '';
			if (!artistData.length) {
				renderEmptyArtistsState();
				return;
			}
			const grouped = new Map<number, Album[]>();
			for (const album of albumData) {
				const current = grouped.get(album.artist_id) ?? [];
				current.push(album);
				grouped.set(album.artist_id, current);
			}
			const visibleArtists = artistData.filter((artist) =>
				matchesArtistFilters(artist, grouped.get(artist.id) ?? []) &&
				matchesArtistSearch(artist, grouped.get(artist.id) ?? []),
			);
			if (!visibleArtists.length) {
				renderArtistSearchEmptyState();
				return;
			}
			const sortedArtists = [...visibleArtists].sort((a, b) => {
				let base = 0;
				if (currentSortBy === 'alphabetical') {
					base = a.name.localeCompare(b.name, undefined, { sensitivity: 'base' });
				} else if (currentSortBy === 'createdAt') {
					base = new Date(a.created_at).getTime() - new Date(b.created_at).getTime();
				} else if (currentSortBy === 'averageRating') {
					base = compareOptionalNumber(
						getAverageArtistRating(grouped.get(a.id) ?? []),
						getAverageArtistRating(grouped.get(b.id) ?? []),
					);
				}

				if (base === 0) base = a.name.localeCompare(b.name, undefined, { sensitivity: 'base' });
				return currentSortDirection === 'asc' ? base : -base;
			});
			for (const artist of sortedArtists)
				listRoot.appendChild(renderArtistCard(artist, grouped.get(artist.id) ?? []));
		} catch {
			setMessage('An unexpected error occurred while loading artists.', true);
		} finally {
			if (shouldShowSkeleton) hidePageLoadingSkeleton(route);
		}
	};

	const refreshArtistsView = () => {
		if (!getToolkitInstance()) {
			if (toolkitRetryCount < MAX_TOOLKIT_RETRIES) {
				toolkitRetryCount += 1;
				requestAnimationFrame(refreshArtistsView);
			}
			return;
		}

		toolkitRetryCount = 0;
		bindSearchHandlers();
		bindFilterHandlers();
		bindEditHandlers();
		resetSortControls();
		syncArtistSortControls();
		void loadArtists();
	};

	bindOnce('__artistDirectoryBound', () => {
		window.addEventListener('library-data-changed', () => {
			void loadArtists();
		});
		document.addEventListener('astro:page-load', refreshArtistsView);
	});

	bindOnce('__editArtistSpotifyAvailabilityBound', () => {
		window.addEventListener('online', syncEditArtistSpotifyAvailability);
		window.addEventListener('offline', syncEditArtistSpotifyAvailability);
		document.addEventListener('astro:page-load', syncEditArtistSpotifyAvailability);
	});

	bindOnce('__artistSyncBannerBound', () => {
		window.addEventListener('online', () => syncArtistBanner());
		window.addEventListener('offline', () => syncArtistBanner());
		document.addEventListener('astro:page-load', () => syncArtistBanner());
	});

	refreshArtistsView();
</script>
