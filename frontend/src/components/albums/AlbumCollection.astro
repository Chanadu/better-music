---
import BaseDialog from '../ui/BaseDialog.astro';
import CoverPreviewField from '../ui/CoverPreviewField.astro';
import DialogTabSwitcher from '../ui/DialogTabSwitcher.astro';
import FilterSelect from '../ui/FilterSelect.astro';
import FloatingDateField from '../ui/FloatingDateField.astro';
import FloatingInput from '../ui/FloatingInput.astro';
import FloatingSelect from '../ui/FloatingSelect.astro';
import FloatingTextarea from '../ui/FloatingTextarea.astro';
import InteractiveListToolkit from '../ui/InteractiveListToolkit.astro';
import SearchField from '../ui/SearchField.astro';
import SpotifyRefreshButton from '../ui/SpotifyRefreshButton.astro';
import SpotifySearchPanel from '../ui/SpotifySearchPanel.astro';
import SortControls from '../ui/SortControls.astro';
import SyncStatusBanner from '../ui/SyncStatusBanner.astro';
import { BUTTON_PRIMARY_CLASS } from '../../lib/button-styles';
interface Props {
	view?: 'unlistened' | 'listened';
}

const { view = 'unlistened' } = Astro.props as Props;
---

<section data-album-collection-root='true' data-view={view}>
	<div class='mb-3'>
		<SearchField
			inputId='albums-search'
			label='Search albums'
			placeholder='Search albums, artists, years, or notes'
			wrapperClassName='min-w-0'
			data-albums-search='true'
		/>
	</div>
	<div class='mb-4 flex items-center gap-2 sm:mx-auto sm:w-fit sm:max-w-full sm:justify-center sm:gap-3'>
		<FilterSelect
			selectId='albums-artist-filter'
			label='Filter by artist'
			wrapperClassName='min-w-0 flex-1 sm:w-[14rem] sm:flex-none'
			data-albums-artist-filter='true'
		>
			<option value='all'>All artists</option>
		</FilterSelect>
		<SortControls
			controlId='albums-sort-by'
			containerClass='grid min-w-0 flex-1 grid-cols-[minmax(0,1fr)_auto] items-center gap-1.5 sm:w-auto sm:max-w-full sm:flex-none sm:shrink-0 sm:grid-cols-[auto_auto_auto] sm:gap-3'
		/>
	</div>

	<SyncStatusBanner bannerId='albums-sync-banner' textId='albums-sync-banner-text' className='mb-4' />

	<div id='albums-list' data-view={view} class='space-y-3'></div>
</section>

<InteractiveListToolkit />

<BaseDialog
	id='edit-album-modal'
	className='border-border bg-surface text-text m-auto w-[min(92vw,36rem)] rounded-2xl border p-0 shadow-2xl backdrop:bg-black/45'
	contentClassName=''
	mobilePlacement='center'
>
	<form id='edit-album-form' class='space-y-4 p-6 pb-8 sm:p-5 sm:pb-5'>
		<div class='flex items-center justify-between'>
			<h3 class='text-lg font-semibold'>Edit Album</h3>
		</div>

		<input id='edit-album-id' type='hidden' />
		<DialogTabSwitcher manualButtonId='edit-album-tab-manual' spotifyButtonId='edit-album-tab-spotify' />
		<div id='edit-album-manual-panel' class='space-y-4'>
			<FloatingInput id='edit-album-title' label='Title' required />
			<FloatingSelect id='edit-album-artist-id' label='Artist' required />
			<CoverPreviewField
				inputId='edit-album-cover-url'
				imageId='edit-album-cover-preview'
				emptyId='edit-album-cover-empty'
				label='Cover Art'
				emptyLabel='No cover image available'
				imageAlt='Album cover preview'
			/>
			<FloatingInput id='edit-album-year' label='Year' type='number' min='0' />
			<SpotifyRefreshButton buttonId='edit-album-spotify-refresh-btn' />
			<label for='edit-album-listened' class='flex items-center gap-2 text-sm font-semibold'
				><input
					id='edit-album-listened'
					type='checkbox'
					class='border-border/60 bg-surface-raised/50 text-primary focus:ring-primary/50 h-5 w-5 rounded border transition-all duration-200 focus:ring-2'
				/> Listened</label
			>
			<div class='flex items-center gap-2 sm:gap-3'>
				<input
					id='edit-album-rating-slider'
					type='range'
					min='0'
					max='10'
					step='0.1'
					value='5'
					class='bg-border/50 accent-primary h-3 w-full cursor-pointer appearance-none rounded-lg disabled:opacity-50'
				/>
				<div class='relative w-20 shrink-0'>
					<FloatingInput
						id='edit-album-rating'
						label='Rating'
						type='number'
						min='0'
						max='10'
						step='0.1'
						inputmode='decimal'
						inputClassName='h-11 px-2 pb-1 pt-4 text-sm disabled:opacity-50'
						labelClassName='left-2 top-1 text-[10px] peer-placeholder-shown:text-xs peer-focus:top-1 peer-focus:text-[10px]'
					/>
				</div>
			</div>
			<FloatingDateField id='edit-album-listened-at' label='Listened At (optional)' />
		</div>
		<SpotifySearchPanel
			panelId='edit-album-spotify-panel'
			searchInputId='edit-album-spotify-search'
			spinnerId='edit-album-spotify-spinner'
			resultsId='edit-album-spotify-results'
			warningId='edit-album-spotify-offline-warning'
			searchLabel='Search Spotify Albums'
			hint='Select a Spotify album to replace the saved metadata for this entry.'
			offlineMessage='Spotify search is unavailable offline. Switch back to Manual to keep editing without reconnecting.'
			className='hidden'
		/>
		<p id='edit-album-status' class='text-text-muted text-sm'></p>
		<div class='flex flex-col-reverse gap-3 pt-2 sm:flex-row sm:items-center sm:justify-center sm:pt-0'>
			<button
				type='submit'
				id='edit-album-submit'
				class:list={[BUTTON_PRIMARY_CLASS, 'w-full sm:w-auto']}
				>Save Album</button
			>
		</div>
	</form>
</BaseDialog>

<BaseDialog
	id='quick-listened-modal'
	className='border-border bg-surface text-text m-auto w-[min(92vw,32rem)] rounded-2xl border p-0 shadow-2xl backdrop:bg-black/45'
	contentClassName='p-5 sm:p-6'
	mobilePlacement='center'
>
	<form id='quick-listened-form' class='space-y-4'>
		<div class='space-y-1'>
			<p class='text-text-muted text-[11px] font-semibold uppercase tracking-[0.24em]'>Quick Update</p>
			<h3 class='text-xl font-semibold tracking-tight text-text'>Mark as Listened</h3>
			<p id='quick-listened-context' class='text-sm text-text-muted'></p>
		</div>

		<input id='quick-listened-album-id' type='hidden' />

		<div>
			<label for='quick-listened-rating' class='block text-sm font-semibold'>Rating</label>
			<div class='mt-2 space-y-3'>
				<div class='flex items-center gap-2 sm:gap-3'>
					<input
						id='quick-listened-rating-slider'
						type='range'
						min='0'
						max='10'
						step='0.1'
						value='5'
						class='bg-border/50 accent-primary h-3 w-full cursor-pointer appearance-none rounded-lg'
					/>
					<div class='relative w-20 shrink-0'>
						<FloatingInput
							id='quick-listened-rating'
							label='Rating'
							type='number'
							min='0'
							max='10'
							step='0.1'
							inputmode='decimal'
							inputClassName='h-11 px-2 pb-1 pt-4 text-sm'
							labelClassName='left-2 top-1 text-[10px] peer-placeholder-shown:text-xs peer-focus:top-1 peer-focus:text-[10px]'
						/>
					</div>
				</div>
			</div>
		</div>

		<FloatingTextarea id='quick-listened-comment' label='Comment (optional)' rows={4} />

		<p id='quick-listened-status' class='text-text-muted text-sm'></p>

		<div class='flex flex-col-reverse gap-3 pt-2 sm:flex-row sm:items-center sm:justify-center sm:pt-0'>
			<button
				type='submit'
				id='quick-listened-submit'
				class:list={[BUTTON_PRIMARY_CLASS, 'w-full sm:w-auto']}
			>
				Save Listening
			</button>
		</div>
	</form>
</BaseDialog>

<script>
	import Sortable from 'sortablejs';
	import { BUTTON_COMPACT_ICON_SECONDARY_CLASS } from '../../lib/button-styles';
	import { syncCoverPreview } from '../../lib/cover-preview';
	import { closeDialogSafely, openDialogSafely, toggleDialogTabs } from '../../lib/dialog';
	import { formatDateTime, getCurrentDateLocal, toDateLocal } from '../../lib/date';
	import { createEmptyState } from '../../lib/empty-state';
	import { bindOnce } from '../../lib/events';
	import {
		deleteAlbumRecord,
		hasCachedLibraryData,
		loadLibraryData,
		updateAlbumRecord,
		type UpdateAlbumInput,
	} from '../../lib/library-cache';
	import { hidePageLoadingSkeleton, showPageLoadingSkeleton } from '../../lib/page-skeletons';
	import { getAlbumBySpotifyID, searchAlbums, type SpotifyAlbum } from '../../lib/spotify';
	import {
		bindSpotifySearch,
		getSpotifySearchElements,
		isNavigatorOnline,
		resetSpotifySearch,
		syncSpotifySearchAvailability,
	} from '../../lib/spotify-search';
	import { initializeSortControls, type SortDirection } from '../../lib/sort';
	import { ICON_PATHS, applyRatingTone, createAlbumPill } from '../../lib/ui';

	type EntitySyncState = 'synced' | 'pending';

	type Album = {
		id: number;
		artist_id: number;
		title: string;
		cover_url?: string | null;
		year?: number | null;
		spotify_id?: string | null;
		listened: boolean;
		rating?: number | null;
		comment?: string | null;
		listened_at?: string | null;
		created_at: string;
		local_only?: boolean;
		sync_state?: EntitySyncState;
	};

	type Artist = {
		id: number;
		name: string;
		local_only?: boolean;
		sync_state?: EntitySyncState;
	};

	type SortableEndEvent = {
		newIndex?: number | null;
		oldIndex?: number | null;
	};

	type AlbumSortKey = 'artist' | 'title' | 'year' | 'rating' | 'createdAt' | 'listenedAt';
	type AlbumView = 'unlistened' | 'listened';
	type StatusType = 'neutral' | 'error' | 'success';

	type InteractiveCardOptions = {
		onEdit: () => void;
		onDelete: () => void;
		editLabel: string;
		deleteLabel: string;
		toggleLabel: string;
		enableSwipe?: boolean;
	};

	type InteractiveCardParts = {
		wrapper: HTMLDivElement;
		left: HTMLDivElement;
		right: HTMLDivElement;
		setBody: (body: HTMLElement) => void;
	};

	type InteractiveListToolkitAPI = {
		setListRootMessage: (listRoot: HTMLDivElement | null, message: string, isError?: boolean) => void;
		setStatusText: (target: HTMLElement | null, message: string, type?: StatusType) => void;
		showDialogSafely: (dialog: HTMLDialogElement | null) => void;
		createInteractiveListCard: (options: InteractiveCardOptions) => InteractiveCardParts;
	};

	const getToolkitInstance = () =>
		(window as Window & { __interactiveListToolkit?: InteractiveListToolkitAPI }).__interactiveListToolkit ?? null;

	const getToolkit = () => {
		const toolkit = getToolkitInstance();
		if (!toolkit) throw new Error('Interactive list toolkit unavailable');
		return toolkit;
	};

	const getComponentRoot = () => document.querySelector('[data-album-collection-root="true"]') as HTMLElement | null;
	const getListRoot = () => document.getElementById('albums-list') as HTMLDivElement | null;
	const getSearchInput = () =>
		getComponentRoot()?.querySelector('[data-albums-search="true"]') as HTMLInputElement | null;
	const getArtistFilterInput = () =>
		getComponentRoot()?.querySelector('[data-albums-artist-filter="true"]') as HTMLSelectElement | null;
	const getSyncBanner = () => document.getElementById('albums-sync-banner') as HTMLDivElement | null;
	const getSyncBannerText = () => document.getElementById('albums-sync-banner-text') as HTMLParagraphElement | null;
	const getEditAlbumSpotifyElements = () =>
		getSpotifySearchElements({
			inputId: 'edit-album-spotify-search',
			spinnerId: 'edit-album-spotify-spinner',
			resultsId: 'edit-album-spotify-results',
			warningId: 'edit-album-spotify-offline-warning',
		});
	const getView = (): 'unlistened' | 'listened' => {
		const mode = getListRoot()?.dataset.view;
		return mode === 'listened' ? 'listened' : 'unlistened';
	};
	const isOnline = isNavigatorOnline;
	let editAlbumDialog: HTMLDialogElement | null = null;
	let editAlbumForm: HTMLFormElement | null = null;
	let editAlbumIDInput: HTMLInputElement | null = null;
	let editAlbumTitleInput: HTMLInputElement | null = null;
	let editAlbumArtistInput: HTMLSelectElement | null = null;
	let editAlbumCoverInput: HTMLInputElement | null = null;
	let editAlbumYearInput: HTMLInputElement | null = null;
	let editAlbumListenedInput: HTMLInputElement | null = null;
	let editAlbumRatingSliderInput: HTMLInputElement | null = null;
	let editAlbumRatingInput: HTMLInputElement | null = null;
	let editAlbumListenedAtInput: HTMLInputElement | null = null;
	let editAlbumStatus: HTMLParagraphElement | null = null;
	let editAlbumSubmit: HTMLButtonElement | null = null;
	let quickListenedDialog: HTMLDialogElement | null = null;
	let quickListenedForm: HTMLFormElement | null = null;
	let quickListenedAlbumIDInput: HTMLInputElement | null = null;
	let quickListenedContext: HTMLParagraphElement | null = null;
	let quickListenedRatingSliderInput: HTMLInputElement | null = null;
	let quickListenedRatingInput: HTMLInputElement | null = null;
	let quickListenedCommentInput: HTMLTextAreaElement | null = null;
	let quickListenedStatus: HTMLParagraphElement | null = null;
	let quickListenedSubmit: HTMLButtonElement | null = null;
	let currentQuickListenedAlbum: Album | null = null;
	let listenedSortable: any = null;
	let currentEditAlbumSpotifyID: string | null = null;
	let currentSortBy: AlbumSortKey = 'artist';
	let currentSortDirection: SortDirection = 'asc';
	let currentSearchQuery = '';
	let currentArtistFilter = 'all';
	let initializedSortView: AlbumView | null = null;
	let toolkitRetryCount = 0;
	let lastLoadedAlbums: Album[] = [];
	let lastLoadedArtists: Artist[] = [];
	const MAX_TOOLKIT_RETRIES = 18;

	const getNormalizedSearchQuery = () => currentSearchQuery.trim().toLocaleLowerCase();
	const hasPendingSync = (entity: { local_only?: boolean; sync_state?: EntitySyncState | null }) =>
		Boolean(entity.local_only) || entity.sync_state === 'pending';
	const hasActiveAlbumFilters = () =>
		Boolean(getNormalizedSearchQuery()) || currentArtistFilter !== 'all';
	const syncThemedFilterSelect = (select: HTMLSelectElement | null) => {
		select?.dispatchEvent(new Event('themed-select-sync'));
	};

	const getDefaultSortState = (view: AlbumView): { sortBy: AlbumSortKey; sortDirection: SortDirection } => {
		return view === 'listened' ?
				{ sortBy: 'rating', sortDirection: 'desc' }
			:	{ sortBy: 'artist', sortDirection: 'asc' };
	};

	const refreshEditRefs = () => {
		editAlbumDialog = document.getElementById('edit-album-modal') as HTMLDialogElement | null;
		editAlbumForm = document.getElementById('edit-album-form') as HTMLFormElement | null;
		editAlbumIDInput = document.getElementById('edit-album-id') as HTMLInputElement | null;
		editAlbumTitleInput = document.getElementById('edit-album-title') as HTMLInputElement | null;
		editAlbumArtistInput = document.getElementById('edit-album-artist-id') as HTMLSelectElement | null;
		editAlbumCoverInput = document.getElementById('edit-album-cover-url') as HTMLInputElement | null;
		editAlbumYearInput = document.getElementById('edit-album-year') as HTMLInputElement | null;
		editAlbumListenedInput = document.getElementById('edit-album-listened') as HTMLInputElement | null;
		editAlbumRatingSliderInput = document.getElementById('edit-album-rating-slider') as HTMLInputElement | null;
		editAlbumRatingInput = document.getElementById('edit-album-rating') as HTMLInputElement | null;
		editAlbumListenedAtInput = document.getElementById('edit-album-listened-at') as HTMLInputElement | null;
		editAlbumStatus = document.getElementById('edit-album-status') as HTMLParagraphElement | null;
		editAlbumSubmit = document.getElementById('edit-album-submit') as HTMLButtonElement | null;
	};

	const refreshQuickListenedRefs = () => {
		quickListenedDialog = document.getElementById('quick-listened-modal') as HTMLDialogElement | null;
		quickListenedForm = document.getElementById('quick-listened-form') as HTMLFormElement | null;
		quickListenedAlbumIDInput = document.getElementById('quick-listened-album-id') as HTMLInputElement | null;
		quickListenedContext = document.getElementById('quick-listened-context') as HTMLParagraphElement | null;
		quickListenedRatingSliderInput = document.getElementById(
			'quick-listened-rating-slider',
		) as HTMLInputElement | null;
		quickListenedRatingInput = document.getElementById('quick-listened-rating') as HTMLInputElement | null;
		quickListenedCommentInput = document.getElementById('quick-listened-comment') as HTMLTextAreaElement | null;
		quickListenedStatus = document.getElementById('quick-listened-status') as HTMLParagraphElement | null;
		quickListenedSubmit = document.getElementById('quick-listened-submit') as HTMLButtonElement | null;
	};

	const setEditAlbumCover = (url: string | null | undefined) => {
		syncCoverPreview(
			editAlbumCoverInput,
			document.getElementById('edit-album-cover-preview') as HTMLImageElement | null,
			document.getElementById('edit-album-cover-empty') as HTMLParagraphElement | null,
			url,
		);
	};

	const switchEditAlbumTab = (tab: 'manual' | 'spotify') => {
		toggleDialogTabs(tab, {
			manualPanel: document.getElementById('edit-album-manual-panel'),
			spotifyPanel: document.getElementById('edit-album-spotify-panel'),
			manualButton: document.getElementById('edit-album-tab-manual'),
			spotifyButton: document.getElementById('edit-album-tab-spotify'),
			searchInput: getEditAlbumSpotifyElements().input,
		});
	};

	const resetEditAlbumSpotifySearch = () => {
		resetSpotifySearch(getEditAlbumSpotifyElements());
	};

	const syncEditAlbumSpotifyAvailability = () => {
		syncSpotifySearchAvailability(getEditAlbumSpotifyElements(), { isOnline });
	};

	const clampRating = (value: number) => Math.min(10, Math.max(0, value));

	const syncEditRatingControls = (source: 'slider' | 'manual') => {
		if (!editAlbumRatingSliderInput || !editAlbumRatingInput) return;

		if (source === 'slider') {
			const value = clampRating(Number(editAlbumRatingSliderInput.value));
			if (!Number.isFinite(value)) return;
			editAlbumRatingInput.value = value.toFixed(1);
			return;
		}

		const parsed = Number(editAlbumRatingInput.value);
		if (!Number.isFinite(parsed)) return;
		const value = clampRating(parsed);
		editAlbumRatingSliderInput.value = value.toFixed(1);
		editAlbumRatingInput.value = value.toFixed(1);
	};

	let artistsCache: Artist[] = [];

	const compareText = (a: string, b: string) => a.localeCompare(b, undefined, { sensitivity: 'base' });
	const normalizeArtistName = (value: string) => value.trim().toLowerCase();

	const compareOptionalNumber = (a?: number | null, b?: number | null) => {
		if (a == null && b == null) return 0;
		if (a == null) return 1;
		if (b == null) return -1;
		return a - b;
	};

	const compareOptionalDate = (a?: string | null, b?: string | null) => {
		if (!a && !b) return 0;
		if (!a) return 1;
		if (!b) return -1;
		return new Date(a).getTime() - new Date(b).getTime();
	};

	const syncAlbumBanner = (albums = lastLoadedAlbums, artists = lastLoadedArtists) => {
		const banner = getSyncBanner();
		const text = getSyncBannerText();
		if (!banner || !text) return;

		const pendingCount =
			albums.filter((album) => hasPendingSync(album)).length +
			artists.filter((artist) => hasPendingSync(artist)).length;

		if (pendingCount === 0) {
			banner.classList.add('hidden');
			text.textContent = '';
			return;
		}

		banner.classList.remove('hidden');
		text.textContent =
			isOnline() ?
				`${pendingCount} change${pendingCount === 1 ? '' : 's'} pending sync. The app will keep retrying automatically.`
			:	`${pendingCount} change${pendingCount === 1 ? '' : 's'} saved offline. They will sync when you reconnect.`;
	};

	const syncAlbumArtistFilterOptions = (artists: Artist[]) => {
		const filterInput = getArtistFilterInput();
		if (!filterInput) return;

		const previousValue = currentArtistFilter;
		filterInput.innerHTML = '';

		const allOption = document.createElement('option');
		allOption.value = 'all';
		allOption.textContent = 'All artists';
		filterInput.appendChild(allOption);

		for (const artist of artists) {
			const option = document.createElement('option');
			option.value = String(artist.id);
			option.textContent = artist.name;
			filterInput.appendChild(option);
		}

		const nextValue =
			previousValue === 'all' || artists.some((artist) => String(artist.id) === previousValue) ? previousValue : 'all';
		currentArtistFilter = nextValue;
		filterInput.value = nextValue;
		syncThemedFilterSelect(filterInput);
	};

	const resetAlbumFilters = () => {
		currentSearchQuery = '';
		currentArtistFilter = 'all';

		const searchInput = getSearchInput();
		if (searchInput) searchInput.value = '';
		const artistFilterInput = getArtistFilterInput();
		if (artistFilterInput) {
			artistFilterInput.value = 'all';
			syncThemedFilterSelect(artistFilterInput);
		}
	};

	const matchesAlbumFilters = (album: Album) => {
		if (currentArtistFilter !== 'all' && String(album.artist_id) !== currentArtistFilter) return false;
		return true;
	};

	const sortAlbums = (albums: Album[], artistNameMap: Map<number, string>): Album[] => {
		const mode = getView();
		const isListenedView = mode === 'listened';
		return [...albums].sort((a, b) => {
			const artistA = artistNameMap.get(a.artist_id) ?? '';
			const artistB = artistNameMap.get(b.artist_id) ?? '';

			let base = 0;
			if (currentSortBy === 'artist') {
				base = compareText(artistA, artistB);
			} else if (currentSortBy === 'title') {
				base = compareText(a.title, b.title);
			} else if (currentSortBy === 'year') {
				base = compareOptionalNumber(a.year, b.year);
			} else if (currentSortBy === 'rating' && isListenedView) {
				base = compareOptionalNumber(a.rating, b.rating);
			} else if (currentSortBy === 'createdAt') {
				base = compareOptionalDate(a.created_at, b.created_at);
			} else if (currentSortBy === 'listenedAt' && isListenedView) {
				base = compareOptionalDate(a.listened_at, b.listened_at);
			}

			if (base === 0) {
				base = compareText(a.title, b.title);
				if (base === 0) base = compareText(artistA, artistB);
			}

			return currentSortDirection === 'asc' ? base : -base;
		});
	};

	const syncAlbumSortControls = () => {
		const mode = getView();

		if (initializedSortView !== mode) {
			const defaults = getDefaultSortState(mode);
			currentSortBy = defaults.sortBy;
			currentSortDirection = defaults.sortDirection;
			initializedSortView = mode;
		}

		const options: Array<{ value: AlbumSortKey; label: string }> =
			mode === 'listened' ?
				[
					{ value: 'rating', label: 'Rating' },
					{ value: 'artist', label: 'Artist Name' },
					{ value: 'title', label: 'Album Name' },
					{ value: 'year', label: 'Year' },
					{ value: 'createdAt', label: 'Creation Date' },
					{ value: 'listenedAt', label: 'Listened Date' },
				]
			:	[
					{ value: 'artist', label: 'Artist Name' },
					{ value: 'title', label: 'Album Name' },
					{ value: 'year', label: 'Year' },
					{ value: 'createdAt', label: 'Creation Date' },
				];

		initializeSortControls({
			controlPrefix: 'albums-sort',
			options,
			getSortBy: () => currentSortBy,
			setSortBy: (value) => {
				currentSortBy = value;
			},
			getSortDirection: () => currentSortDirection,
			setSortDirection: (value) => {
				currentSortDirection = value;
			},
			onChange: () => void loadAlbums(),
		});
	};

	const setMessage = (message: string, isError = false) =>
		getToolkit().setListRootMessage(getListRoot(), message, isError);

	const renderEmptyAlbumsState = (view: AlbumView) => {
		const listRoot = getListRoot();
		if (!listRoot) return;

		const isListened = view === 'listened';
		listRoot.replaceChildren(
			createEmptyState({
				title: isListened ? 'No listened albums yet' : 'No albums in queue',
				description:
					isListened ?
						'Add an album and mark it listened when you are ready to rate it.'
					:	'Add an album to your queue to keep track of what to hear next.',
				buttonLabel: 'Create Album',
				onClick: () => window.dispatchEvent(new CustomEvent('open-album-modal')),
			}),
		);
	};

	const clearAlbumSearch = () => {
		currentSearchQuery = '';
		const searchInput = getSearchInput();
		if (searchInput) searchInput.value = '';
	};

	const renderAlbumSearchEmptyState = (view: AlbumView) => {
		const listRoot = getListRoot();
		if (!listRoot) return;

		const modeLabel = view === 'listened' ? 'listened albums' : 'queue';
		listRoot.replaceChildren(
			createEmptyState({
				title: `No matches in ${modeLabel}`,
				description:
					'Nothing matched the current search and filters. Adjust them or reset to see your full library again.',
				buttonLabel: 'Reset Filters',
				onClick: () => {
					resetAlbumFilters();
					void loadAlbums();
				},
			}),
		);
	};

	const clearListenedState = () => {
		if (listenedSortable) {
			listenedSortable.destroy();
			listenedSortable = null;
		}

		const oldHint = getComponentRoot()?.querySelector('[data-listened-hint="true"]');
		if (oldHint) oldHint.remove();
	};

	const setEditStatus = (message: string, type: 'neutral' | 'error' | 'success' = 'neutral') => {
		getToolkit().setStatusText(editAlbumStatus, message, type);
	};

	const setQuickListenedStatus = (message: string, type: 'neutral' | 'error' | 'success' = 'neutral') => {
		getToolkit().setStatusText(quickListenedStatus, message, type);
	};

	const autoSelectEditArtistFromSpotifyNames = (spotifyArtistNames: string[]): boolean => {
		if (!editAlbumArtistInput || spotifyArtistNames.length === 0) return false;

		const targets = new Set(spotifyArtistNames.map(normalizeArtistName));
		for (const option of Array.from(editAlbumArtistInput.options)) {
			if (!option.value) continue;
			if (targets.has(normalizeArtistName(option.textContent ?? ''))) {
				editAlbumArtistInput.value = option.value;
				editAlbumArtistInput.dispatchEvent(new Event('themed-select-sync'));
				return true;
			}
		}

		return false;
	};

	const applySpotifyAlbumToEditForm = (album: SpotifyAlbum, options: { switchToManual?: boolean } = {}) => {
		if (!editAlbumTitleInput || !editAlbumYearInput) return;

		const cover = album.images[0]?.url ?? '';
		const year = album.release_date ? album.release_date.slice(0, 4) : '';
		const spotifyArtists = album.artists.map((artist) => artist.name);
		const matchedArtist = autoSelectEditArtistFromSpotifyNames(spotifyArtists);

		currentEditAlbumSpotifyID = album.id;
		editAlbumTitleInput.value = album.name;
		setEditAlbumCover(cover);
		editAlbumYearInput.value = year;
		resetEditAlbumSpotifySearch();
		if (options.switchToManual ?? true) switchEditAlbumTab('manual');

		if (spotifyArtists.length === 0) {
			setEditStatus('Spotify metadata applied. Review and save.', 'success');
			return;
		}

		if (matchedArtist) {
			setEditStatus(
				`Spotify metadata applied. Matched artist: ${spotifyArtists[0]}. Review and save.`,
				'success',
			);
			return;
		}

		setEditStatus(
			`Spotify metadata applied. No local artist matched ${spotifyArtists[0]}, so choose one manually before saving.`,
			'neutral',
		);
	};

	const renderEditAlbumResult = (album: SpotifyAlbum) => {
		const img = album.images[0];
		const year = album.release_date ? album.release_date.slice(0, 4) : '';
		const artistNames = album.artists.map((artist) => artist.name).join(', ');
		const item = document.createElement('li');
		item.className =
			'border-border/30 flex cursor-pointer items-center gap-3 border-b px-4 py-3 text-sm transition-colors hover:bg-surface-raised last:border-0';
		item.innerHTML = `
			${img ? `<img src="${img.url}" alt="" class="h-11 w-11 shrink-0 rounded-lg border border-border/40 object-cover" />` : '<div class="bg-surface-raised flex h-11 w-11 shrink-0 items-center justify-center rounded-lg border border-border/40 text-xs text-text-muted">?</div>'}
			<div class="min-w-0 flex-1">
				<p class="truncate font-medium text-text">${album.name}</p>
				<p class="truncate text-xs text-text-muted">${artistNames}${year ? ` · ${year}` : ''}</p>
			</div>
			<span class="text-secondary ml-auto shrink-0 text-xs font-medium">Select →</span>
		`;
		item.addEventListener('click', () => applySpotifyAlbumToEditForm(album));
