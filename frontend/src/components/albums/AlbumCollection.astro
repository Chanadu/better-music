	const updateAlbumRating = async (album: Album, newRating: number): Promise<boolean> => {
		try {
			await updateAlbumRecord(album.id, {
				artist_id: album.artist_id,
				title: album.title,
				listened: true,
				rating: newRating,
			});
			return true;
		} catch {
			return false;
		}
	};

	const setupListenedReorder = (albums: Album[]) => {
		if (getView() !== 'listened') return;
		const listRoot = getListRoot();
		if (!listRoot) return;

		clearListenedState();

		const albumById = new Map<number, Album>();
		for (const album of albums) albumById.set(album.id, album);

		listenedSortable = new Sortable(listRoot, {
			animation: 180,
			ghostClass: 'album-drag-ghost',
			chosenClass: 'album-drag-chosen',
			dragClass: 'album-drag-active',
			forceFallback: false,
			delay: 280,
			delayOnTouchOnly: true,
			touchStartThreshold: 4,
			onEnd: async (event: SortableEndEvent) => {
				if (event.newIndex == null || event.oldIndex == null || event.newIndex === event.oldIndex) return;

				const items = Array.from(listRoot.children) as HTMLElement[];
				const movedItem = items[event.newIndex];
				const movedId = Number(movedItem?.dataset.albumId);
				if (!movedId) return;
				const movedAlbum = albumById.get(movedId);
				if (!movedAlbum) return;

				const nextId = Number(items[event.newIndex + 1]?.dataset.albumId || 0);
				const prevId = Number(items[event.newIndex - 1]?.dataset.albumId || 0);
				const nextAlbum = nextId ? albumById.get(nextId) : undefined;
				const prevAlbum = prevId ? albumById.get(prevId) : undefined;

				const neighborRating = nextAlbum?.rating ?? prevAlbum?.rating ?? null;
				if (neighborRating == null || neighborRating < 1 || neighborRating > 10) {
					window.alert('Could not infer a target rating from neighboring albums.');
					void loadAlbums();
					return;
				}

				const previousRating = movedAlbum.rating;
				if (previousRating === neighborRating) return;

				movedAlbum.rating = neighborRating;
				const ratingValue = movedItem.querySelector('.album-rating-value');
				const ratingBadge = movedItem.querySelector('.album-rating-badge') as HTMLElement | null;
				if (ratingValue) ratingValue.textContent = String(neighborRating);
				if (ratingBadge) applyRatingTone(ratingBadge, Number(neighborRating), '--surface-raised');

				const saved = await updateAlbumRating(movedAlbum, neighborRating);
				if (!saved) {
					movedAlbum.rating = previousRating;
					if (ratingValue) ratingValue.textContent = String(previousRating ?? '');
					if (ratingBadge && previousRating != null)
						applyRatingTone(ratingBadge, Number(previousRating), '--surface-raised');
					window.alert('Failed to update album ranking.');
					void loadAlbums();
					return;
				}
			},
		});
	};

	const matchesAlbumSearch = (album: Album, artistName: string) => {
		const query = getNormalizedSearchQuery();
		if (!query) return true;

		return [
			album.title,
			artistName,
			album.year == null ? '' : String(album.year),
			album.comment ?? '',
			album.rating == null ? '' : String(album.rating),
		].some((value) => value.toLocaleLowerCase().includes(query));
	};

	const bindEditAlbumSpotifySearch = () => {
		bindSpotifySearch({
			elements: getEditAlbumSpotifyElements(),
			search: searchAlbums,
			renderResult: renderEditAlbumResult,
			isOnline,
		});
	};

	const bindSearchHandlers = () => {
		const searchInput = getSearchInput();
		if (!searchInput || searchInput.dataset.bound === 'true') return;

		searchInput.dataset.bound = 'true';
		searchInput.value = currentSearchQuery;
		searchInput.addEventListener('input', () => {
			currentSearchQuery = searchInput.value;
			void loadAlbums();
		});
		searchInput.addEventListener('search', () => {
			currentSearchQuery = searchInput.value;
			void loadAlbums();
		});
	};

	const bindFilterHandlers = () => {
		const artistFilterInput = getArtistFilterInput();
		if (artistFilterInput) {
			artistFilterInput.value = currentArtistFilter;
			syncThemedFilterSelect(artistFilterInput);
		}
		if (artistFilterInput && artistFilterInput.dataset.bound !== 'true') {
			artistFilterInput.dataset.bound = 'true';
			artistFilterInput.addEventListener('change', () => {
				currentArtistFilter = artistFilterInput.value;
				void loadAlbums();
			});
		}
	};

	const loadAlbums = async () => {
		const listRoot = getListRoot();
		if (!listRoot) return;
		const route = getView() === 'listened' ? '/listened' : '/albums';
		const shouldShowSkeleton = !hasCachedLibraryData();
		if (shouldShowSkeleton) showPageLoadingSkeleton(route);
		listRoot.innerHTML = '';
		try {
			const { albums, artists } = await loadLibraryData();
			const albumData = albums as Album[];
			const artistData = artists as Artist[];
			lastLoadedAlbums = albumData;
			lastLoadedArtists = artistData;
			artistsCache = [...artistData].sort((a, b) => a.name.localeCompare(b.name));
			syncAlbumArtistFilterOptions(artistsCache);
			syncAlbumBanner();
			const mode = getView();
			syncAlbumSortControls();
			const filteredAlbums = albumData.filter((album) => album.listened === (mode === 'listened'));
			listRoot.innerHTML = '';
			if (!filteredAlbums.length) {
				clearListenedState();
				renderEmptyAlbumsState(mode);
				return;
			}
			const artistNameMap = new Map<number, string>();
			for (const artist of artistData) artistNameMap.set(artist.id, artist.name);
			const visibleAlbums = filteredAlbums.filter((album) =>
				matchesAlbumFilters(album) && matchesAlbumSearch(album, artistNameMap.get(album.artist_id) ?? ''),
			);
			if (!visibleAlbums.length) {
				clearListenedState();
				renderAlbumSearchEmptyState(mode);
				return;
			}

			if (mode === 'listened' && !hasActiveAlbumFilters()) {
				setupListenedReorder(visibleAlbums);
			} else {
				clearListenedState();
			}

			const sortedAlbums = sortAlbums(visibleAlbums, artistNameMap);
			for (const album of sortedAlbums) {
				const artistName = artistNameMap.get(album.artist_id) ?? `Artist #${album.artist_id}`;
				listRoot.appendChild(renderAlbumCard(album, artistName));
			}
		} catch {
			setMessage('An unexpected error occurred while loading albums.', true);
		} finally {
			if (shouldShowSkeleton) hidePageLoadingSkeleton(route);
		}
	};

	const refreshAlbumsView = () => {
		if (!getToolkitInstance()) {
			if (toolkitRetryCount < MAX_TOOLKIT_RETRIES) {
				toolkitRetryCount += 1;
				requestAnimationFrame(refreshAlbumsView);
			}
			return;
		}

		toolkitRetryCount = 0;
		bindSearchHandlers();
		bindFilterHandlers();
		bindEditHandlers();
		bindQuickListenedHandlers();
		syncAlbumSortControls();
		void loadAlbums();
	};

	const bindEditHandlers = () => {
		refreshEditRefs();
		if (!editAlbumForm || editAlbumForm.dataset.bound === 'true') return;
		editAlbumForm.dataset.bound = 'true';

		editAlbumDialog?.addEventListener('click', (event) => {
			if (editAlbumDialog && event.target === editAlbumDialog) editAlbumDialog.close();
		});
		document.getElementById('edit-album-tab-manual')?.addEventListener('click', () => switchEditAlbumTab('manual'));
		document.getElementById('edit-album-tab-spotify')?.addEventListener('click', () => {
			syncEditAlbumSpotifyAvailability();
			switchEditAlbumTab('spotify');
		});
		bindEditAlbumSpotifySearch();
		editAlbumListenedInput?.addEventListener('change', syncEditListenedState);
		editAlbumRatingSliderInput?.addEventListener('input', () => syncEditRatingControls('slider'));
		editAlbumRatingInput?.addEventListener('input', () => syncEditRatingControls('manual'));
		editAlbumRatingInput?.addEventListener('change', () => syncEditRatingControls('manual'));

		const refreshSpotifyButton = document.getElementById(
			'edit-album-spotify-refresh-btn',
		) as HTMLButtonElement | null;
		refreshSpotifyButton?.addEventListener('click', async () => {
			if (!editAlbumTitleInput || !editAlbumCoverInput || !editAlbumYearInput) return;
			if (!currentEditAlbumSpotifyID) {
				setEditStatus('This album does not have a saved Spotify match to refresh.', 'error');
				return;
			}

			refreshSpotifyButton.disabled = true;
			refreshSpotifyButton.textContent = 'Refreshing...';
			setEditStatus('Refreshing from Spotify...');

			try {
				const album = await getAlbumBySpotifyID(currentEditAlbumSpotifyID);
				applySpotifyAlbumToEditForm(album, { switchToManual: false });
			} catch {
				setEditStatus('Failed to refresh from Spotify.', 'error');
			} finally {
				refreshSpotifyButton.disabled = false;
				refreshSpotifyButton.textContent = 'Refresh from Spotify';
			}
		});

		editAlbumForm.addEventListener('submit', async (event) => {
			event.preventDefault();
			if (
				!editAlbumIDInput ||
				!editAlbumTitleInput ||
				!editAlbumArtistInput ||
				!editAlbumCoverInput ||
				!editAlbumYearInput ||
				!editAlbumListenedInput ||
				!editAlbumRatingInput ||
				!editAlbumListenedAtInput ||
				!editAlbumSubmit
			)
				return;
			if (editAlbumListenedInput.checked && !editAlbumRatingInput.value.trim()) {
				setEditStatus('Rating is required when album is marked as listened.', 'error');
				return;
			}
			const payload: UpdateAlbumInput = {
				artist_id: Number(editAlbumArtistInput.value),
				title: editAlbumTitleInput.value.trim(),
				...(currentEditAlbumSpotifyID ? { spotify_id: currentEditAlbumSpotifyID } : {}),
				listened: editAlbumListenedInput.checked,
			};
			if (editAlbumCoverInput.value.trim()) payload.cover_url = editAlbumCoverInput.value.trim();
			if (editAlbumYearInput.value.trim()) payload.year = Number(editAlbumYearInput.value.trim());
			if (editAlbumListenedInput.checked) payload.rating = Number(editAlbumRatingInput.value.trim());
			if (editAlbumListenedInput.checked && editAlbumListenedAtInput.value)
				payload.listened_at = new Date(editAlbumListenedAtInput.value).toISOString();

			editAlbumSubmit.disabled = true;
			editAlbumSubmit.textContent = 'Saving...';
			setEditStatus('Saving album...');

			try {
				const result = await updateAlbumRecord(Number(editAlbumIDInput.value), payload);
				setEditStatus(
					result.syncStatus === 'synced' ?
						'Album updated successfully.'
					:	'Album updated offline. It will sync when you reconnect.',
					'success',
				);
				editAlbumSubmit.disabled = false;
				editAlbumSubmit.textContent = 'Save Album';
				setTimeout(() => editAlbumDialog?.close(), 250);
				return;
			} catch {
				setEditStatus('Failed to update album.', 'error');
				editAlbumSubmit.disabled = false;
				editAlbumSubmit.textContent = 'Save Album';
				return;
			}
		});
	};

	const bindQuickListenedHandlers = () => {
		refreshQuickListenedRefs();
		if (!quickListenedForm || quickListenedForm.dataset.bound === 'true') return;
		quickListenedForm.dataset.bound = 'true';

		quickListenedDialog?.addEventListener('click', (event) => {
			if (quickListenedDialog && event.target === quickListenedDialog) closeDialogSafely(quickListenedDialog);
		});
		quickListenedRatingSliderInput?.addEventListener('input', () => syncQuickListenedRatingControls('slider'));
		quickListenedRatingInput?.addEventListener('input', () => syncQuickListenedRatingControls('manual'));
		quickListenedRatingInput?.addEventListener('change', () => syncQuickListenedRatingControls('manual'));

		quickListenedForm.addEventListener('submit', async (event) => {
			event.preventDefault();
			if (
				!currentQuickListenedAlbum ||
				!quickListenedRatingInput ||
				!quickListenedCommentInput ||
				!quickListenedSubmit
			)
				return;

			const parsed = Number(quickListenedRatingInput.value.trim());
			if (!Number.isFinite(parsed) || parsed < 0 || parsed > 10) {
				setQuickListenedStatus('Enter a rating between 0 and 10.', 'error');
				return;
			}

			quickListenedSubmit.disabled = true;
			quickListenedSubmit.textContent = 'Saving...';
			setQuickListenedStatus('Saving listening...');

			try {
				const result = await updateAlbumRecord(currentQuickListenedAlbum.id, {
					artist_id: currentQuickListenedAlbum.artist_id,
					title: currentQuickListenedAlbum.title,
					listened: true,
					rating: Math.round(parsed * 10) / 10,
					comment: quickListenedCommentInput.value.trim(),
					listened_at: new Date().toISOString(),
					...(currentQuickListenedAlbum.cover_url ?
						{ cover_url: currentQuickListenedAlbum.cover_url }
					:	{}),
					...(currentQuickListenedAlbum.year != null ? { year: currentQuickListenedAlbum.year } : {}),
					...(currentQuickListenedAlbum.spotify_id ?
						{ spotify_id: currentQuickListenedAlbum.spotify_id }
					:	{}),
				});
				setQuickListenedStatus(
					result.syncStatus === 'synced' ?
						'Album marked as listened.'
					:	'Album saved offline. It will sync when you reconnect.',
					'success',
				);
				quickListenedSubmit.disabled = false;
				quickListenedSubmit.textContent = 'Save Listening';
				setTimeout(() => closeDialogSafely(quickListenedDialog), 250);
				return;
			} catch {
				setQuickListenedStatus('Failed to mark album as listened.', 'error');
				quickListenedSubmit.disabled = false;
				quickListenedSubmit.textContent = 'Save Listening';
			}
		});
	};

	bindOnce('__albumCollectionBound', () => {
		window.addEventListener('library-data-changed', () => {
			void loadAlbums();
		});
		document.addEventListener('astro:page-load', refreshAlbumsView);
	});

	bindOnce('__editAlbumSpotifyAvailabilityBound', () => {
		window.addEventListener('online', syncEditAlbumSpotifyAvailability);
		window.addEventListener('offline', syncEditAlbumSpotifyAvailability);
		document.addEventListener('astro:page-load', syncEditAlbumSpotifyAvailability);
	});

	bindOnce('__albumSyncBannerBound', () => {
		window.addEventListener('online', () => syncAlbumBanner());
		window.addEventListener('offline', () => syncAlbumBanner());
		document.addEventListener('astro:page-load', () => syncAlbumBanner());
	});

	refreshAlbumsView();
</script>
