---
interface Props {
	placeholder?: string;
}

const { placeholder = 'Search' } = Astro.props;
---

<label class='input input-md flex w-full items-center gap-2'>
	<svg
		xmlns='http://www.w3.org/2000/svg'
		viewBox='0 0 24 24'
		fill='none'
		stroke='currentColor'
		stroke-width='2'
		class='h-4 w-4'
		aria-hidden='true'
	>
		<circle cx='11' cy='11' r='7'></circle>
		<path d='m21 21-4.3-4.3'></path>
	</svg>

	<input type='search' class='grow' placeholder={placeholder} />
</label>
