---
interface Props {
	name: string;
	imageUrl?: string;
	artistName: string;
	year?: number;
}

const { name, imageUrl, artistName, year } = Astro.props;

const fallbackInitial = name.trim().charAt(0).toUpperCase() || '?';
const details = [artistName, year].filter(Boolean);
---

<li class='list-row'>
	<div>
		{
			imageUrl ?
				<img class='rounded-box size-10 shrink-0 object-cover' src={imageUrl} alt={`${name} album cover`} />
			:	<div class='rounded-box bg-base-300 flex size-10 shrink-0 items-center justify-center text-sm font-semibold'>
					{fallbackInitial}
				</div>
		}
	</div>
	<div>
		<div>{name}</div>
		<div class='text-base-content/60 text-xs font-semibold uppercase'>
			{details.join(' • ')}
		</div>
	</div>
</li>
