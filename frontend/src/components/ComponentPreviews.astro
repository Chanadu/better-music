---
---

<section class="mb-10">
  <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-text-muted">
    Component Previews
  </h2>
  <div class="flex flex-wrap gap-3">
    <button class="cursor-pointer rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg transition-colors hover:bg-primary-hover">
      Primary button
    </button>
    <button class="cursor-pointer rounded-lg bg-secondary px-4 py-2 text-sm font-semibold text-secondary-fg transition-colors hover:bg-secondary-hover">
      Secondary button
    </button>
    <button class="cursor-pointer rounded-lg border border-border bg-surface px-4 py-2 text-sm font-semibold text-text transition-colors hover:bg-surface-raised">
      Ghost button
    </button>
    <span class="inline-flex items-center rounded-full bg-success/20 px-3 py-1 text-xs font-semibold text-success">
      Success
    </span>
    <span class="inline-flex items-center rounded-full bg-error/20 px-3 py-1 text-xs font-semibold text-error">
      Error
    </span>
    <span class="inline-flex items-center rounded-full bg-warning/20 px-3 py-1 text-xs font-semibold text-warning">
      Warning
    </span>
  </div>
  <div class="mt-4 rounded-xl border border-border bg-surface p-6">
    <h3 class="mb-1 font-semibold text-text">Card title</h3>
    <p class="text-sm text-text-muted">
      This is a sample card using <code class="rounded bg-surface-raised px-1 text-primary">bg-surface</code> with a <code class="rounded bg-surface-raised px-1 text-primary">border-border</code> border.
    </p>
  </div>
</section>
