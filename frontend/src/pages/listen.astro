---
import AddButton from '../components/AddButton.astro';
import CreateAlbumModal from '../components/create/album/CreateAlbumModal.astro';
import SearchBar from '../components/nav/SearchBar.astro';
import TopNav from '../components/nav/TopNav.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<TopNav title='Listen' />

	<div class='navbar'>
		<SearchBar placeholder='album name...' />
	</div>

	<div class='divider mt-2 mb-0'></div>

	<div class='text-base-content/60 mt-4 px-2' data-unrated-album-status>Loading albums...</div>
	<div class='mt-4 grid grid-cols-3 gap-3 px-2 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6' data-unrated-album-grid>
	</div>

	<template data-unrated-album-card-template>
		<div class='min-w-0'>
			<img class='rounded-box aspect-square w-full object-cover' data-album-cover hidden />
			<div
				class='rounded-box bg-base-300 flex aspect-square w-full items-center justify-center text-3xl font-semibold'
				data-album-fallback
			>
			</div>
			<div class='mt-2 text-xs font-semibold text-wrap wrap-break-word' data-album-title></div>
			<div class='text-base-content/60 text-xs font-semibold text-wrap wrap-break-word' data-album-artist></div>
		</div>
	</template>

	<CreateAlbumModal />
	<AddButton />
</Layout>

<script>
	import { onDatabaseData, type Album, type Artist, type DatabaseData } from '../scripts/database';

	type UnratedAlbumItem = {
		album: Album;
		artist?: Artist;
	};

	const albumGrid = document.querySelector<HTMLElement>('[data-unrated-album-grid]');
	const albumStatus = document.querySelector<HTMLElement>('[data-unrated-album-status]');
	const albumCardTemplate = document.querySelector<HTMLTemplateElement>('[data-unrated-album-card-template]');
	const searchInput = document.querySelector<HTMLInputElement>('input[type="search"]');
	let latestData: DatabaseData | null = null;

	const getArtistById = (artists: Artist[]) => {
		const artistsById = new Map<number, Artist>();
		artists.forEach((artist) => artistsById.set(artist.id, artist));
		return artistsById;
	};

	const getUnratedAlbums = ({ albums, artists }: DatabaseData) => {
		const artistsById = getArtistById(artists);

		return albums
			.filter((album) => typeof album.rating !== 'number')
			.map((album) => ({
				album,
				artist: artistsById.get(album.artist_id),
			}));
	};

	const createAlbumCard = ({ album, artist }: UnratedAlbumItem) => {
		const card = albumCardTemplate?.content.firstElementChild?.cloneNode(true) as HTMLElement | undefined;

		if (!card) {
			const missingCard = document.createElement('div');
			missingCard.textContent = album.title;
			return missingCard;
		}

		const image = card.querySelector<HTMLImageElement>('[data-album-cover]');
		const fallback = card.querySelector<HTMLElement>('[data-album-fallback]');
		const title = card.querySelector<HTMLElement>('[data-album-title]');
		const artistName = card.querySelector<HTMLElement>('[data-album-artist]');

		if (album.cover_url) {
			if (image) {
				image.src = album.cover_url;
				image.alt = `${album.title} cover`;
				image.hidden = false;
			}

			if (fallback) {
				fallback.hidden = true;
				fallback.textContent = '';
			}
		} else {
			if (image) {
				image.hidden = true;
				image.removeAttribute('src');
				image.alt = '';
			}

			if (fallback) {
				fallback.hidden = false;
				fallback.textContent = album.title.trim().charAt(0).toUpperCase() || '?';
			}
		}

		if (title) {
			title.textContent = album.title;
		}

		if (artistName) {
			artistName.textContent = artist?.name ?? 'Unknown Artist';
		}

		return card;
	};

	const renderAlbums = () => {
		if (!albumGrid || !latestData) return;

		const query = searchInput?.value.trim().toLowerCase() ?? '';
		const unratedAlbums = getUnratedAlbums(latestData)
			.filter(({ album, artist }) => {
				const title = album.title.toLowerCase();
				const artistName = artist?.name.toLowerCase() ?? '';
				return title.includes(query) || artistName.includes(query);
			})
			.sort((first, second) => first.album.title.localeCompare(second.album.title));

		albumGrid.replaceChildren();

		if (unratedAlbums.length === 0) {
			if (albumStatus) {
				albumStatus.textContent = query ? 'No unrated albums match your search.' : 'No unrated albums yet.';
				albumStatus.hidden = false;
			}
			return;
		}

		if (albumStatus) {
			albumStatus.hidden = true;
		}

		albumGrid.append(...unratedAlbums.map(createAlbumCard));
	};

	onDatabaseData((data) => {
		latestData = data;
		renderAlbums();
	});

	searchInput?.addEventListener('input', renderAlbums);
</script>
