---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Offline | Better-Music">
	<main class="mx-auto max-w-xl px-4 py-16 text-center">
		<h1 class="text-3xl font-semibold" style="color: var(--text);">You are offline</h1>
		<p class="mt-3 text-sm" style="color: var(--text-muted);">
			This page is not available right now. Reconnect and try again.
		</p>
		<a
			href="/"
			class="mt-6 inline-block rounded-lg px-4 py-2 text-sm font-semibold"
			style="background: var(--primary); color: var(--primary-fg);"
		>
			Back to app
		</a>
	</main>
</Layout>
