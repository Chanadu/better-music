---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Offline | Better-Music">
	<main class="mx-auto max-w-xl px-4 py-16 text-center">
		<h1 class="text-3xl font-semibold text-text">You are offline</h1>
		<p class="mt-3 text-sm text-text-muted">
			This page is not available right now. Reconnect and try again.
		</p>
		<a
			href="/"
			class="mt-6 inline-block rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-fg shadow-md transition-all hover:-translate-y-0.5 hover:bg-primary-hover hover:shadow-lg active:scale-95"
		>
			Back to app
		</a>
	</main>
</Layout>
