---
import Layout from '../layouts/Layout.astro';
import Panel from '../components/Panel.astro';
import ThemeToggleButton from '../components/ThemeToggleButton.astro';
---

<Layout>
	<main class="min-h-screen px-4 py-8 sm:px-6 sm:py-12 md:px-8" style="background: linear-gradient(to bottom right, var(--bg), var(--surface-raised));">
		<!-- Header -->
		<div class="mx-auto max-w-4xl">
			<div class="mb-8 flex items-center justify-between gap-4">
				<div class="flex items-center gap-3">
					<div class="flex h-10 w-10 items-center justify-center rounded-lg text-lg font-bold" style="background: var(--primary); color: var(--primary-fg);">
						♪
					</div>
					<h1 class="text-2xl font-bold" style="color: var(--text);">
						Better Music
					</h1>
				</div>

				<div class="flex items-center gap-3">
					<ThemeToggleButton />
					<button
						id="logout-btn"
						class="flex cursor-pointer items-center justify-center rounded-lg border-2 px-3 py-2 text-lg transition-colors hover:opacity-80"
						style="border-color: var(--border); color: var(--text); background: var(--surface);"
					>
						↪
					</button>
				</div>
			</div>

			<!-- Dashboard Content -->
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				<!-- Artists Card -->
				<Panel>
					<div style="color: var(--text);">
						<h2 class="mb-2 text-lg font-semibold">Artists</h2>
						<p class="text-sm" style="color: var(--text-muted);">
							Browse and manage your music collection
						</p>
						<button class="mt-4 rounded-lg px-4 py-2 text-sm font-semibold transition-colors hover:scale-105" style="background: var(--primary); color: var(--primary-fg);">
							View Artists
						</button>
					</div>
				</Panel>

				<!-- Albums Card -->
				<Panel>
					<div style="color: var(--text);">
						<h2 class="mb-2 text-lg font-semibold">Albums</h2>
						<p class="text-sm" style="color: var(--text-muted);">
							Explore albums by your favorite artists
						</p>
						<button class="mt-4 rounded-lg px-4 py-2 text-sm font-semibold transition-colors hover:scale-105" style="background: var(--primary); color: var(--primary-fg);">
							View Albums
						</button>
					</div>
				</Panel>

				<!-- Spotify Integration Card -->
				<Panel>
					<div style="color: var(--text);">
						<h2 class="mb-2 text-lg font-semibold">Spotify</h2>
						<p class="text-sm" style="color: var(--text-muted);">
							Connect and sync with Spotify
						</p>
						<button class="mt-4 rounded-lg px-4 py-2 text-sm font-semibold transition-colors hover:scale-105" style="background: var(--primary); color: var(--primary-fg);">
							Connect
						</button>
					</div>
				</Panel>
			</div>
		</div>
	</main>
</Layout>

<script>
	const logoutBtn = document.getElementById('logout-btn');
	logoutBtn?.addEventListener('click', () => {
		localStorage.removeItem('token');
		window.location.href = '/login';
	});
</script>
