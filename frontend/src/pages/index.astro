---
import AppHeader from '../components/ui/AppHeader.astro';
import AuthGuard from '../components/auth/AuthGuard.astro';
import BottomTabBar from '../components/ui/BottomTabBar.astro';
import CreateMenuModal from '../components/create/CreateMenuModal.astro';
import SectionPanel from '../components/ui/SectionPanel.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<AuthGuard />
	<main class="min-h-screen px-4 py-8 pb-28 sm:px-6 sm:py-12 md:px-8" style="background: linear-gradient(to bottom right, var(--bg), var(--surface-raised));">
		<!-- Header -->
		<div class="mx-auto max-w-4xl">
			<AppHeader title="Home" />

			<!-- Home Content -->
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				<!-- Artists Card -->
				<SectionPanel title="Artists" description="Browse and manage your music collection">
					<a href="/artists" class="inline-block rounded-lg px-4 py-2 text-sm font-semibold transition-colors hover:scale-105" style="background: var(--primary); color: var(--primary-fg);">
						View Artists
					</a>
				</SectionPanel>

				<!-- Albums Card -->
				<SectionPanel title="Albums" description="Explore albums by your favorite artists">
					<a href="/albums" class="inline-block rounded-lg px-4 py-2 text-sm font-semibold transition-colors hover:scale-105" style="background: var(--primary); color: var(--primary-fg);">
						View Albums
					</a>
				</SectionPanel>

				<!-- Create Card -->
				<SectionPanel title="Create" description="Add a new artist or album to your library">
					<button id="home-open-create" type="button" class="inline-block rounded-lg px-4 py-2 text-sm font-semibold transition-colors hover:scale-105" style="background: var(--primary); color: var(--primary-fg);">
						New Entry
					</button>
				</SectionPanel>
			</div>
		</div>
	</main>
	<CreateMenuModal />
	<BottomTabBar current="home" />
</Layout>

<script>
	document.getElementById('home-open-create')?.addEventListener('click', () => {
		window.dispatchEvent(new CustomEvent('open-create-menu'));
	});
</script>
