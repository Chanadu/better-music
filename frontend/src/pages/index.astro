---
import AppPageLayout from '../layouts/AppPageLayout.astro';
---

<AppPageLayout title="Your Library" current="home" maxWidthClass="max-w-5xl" mainClassName="min-h-screen bg-linear-to-br from-bg to-surface-raised px-4 pt-6 pb-28 sm:px-6 sm:pt-8 md:px-8" containerClassName="">
			
			<div class="relative mb-8 flex flex-col justify-end overflow-hidden rounded-4xl bg-surface p-8 shadow-sm ring-1 ring-border/50 sm:min-h-56 sm:p-10">
				<div class="absolute inset-0 bg-linear-to-br from-primary/10 via-primary/5 to-transparent"></div>
				<div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-primary/20 blur-3xl mix-blend-multiply"></div>
				
				<div class="relative z-10">
					<h2 class="text-3xl font-extrabold tracking-tight text-text sm:text-4xl">Welcome back</h2>
					<p class="mt-3 text-lg text-text-muted">A dedicated space for your music collection.</p>
				</div>
			</div>

			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 sm:gap-6">
				<div class="group relative overflow-hidden rounded-3xl border border-border/60 bg-surface-raised p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-linear-to-br hover:from-surface-raised hover:to-primary/5 hover:shadow-md">
					<div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary transition-transform duration-300 group-hover:scale-110">
						<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="12" cy="7" r="4"></circle>
							<path d="M4 21c0-4.2 3.6-7 8-7s8 2.8 8 7"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold tracking-tight text-text group-hover:text-primary">Artists</h3>
					<p class="mt-1 text-sm text-text-muted">Manage the creators behind the music.</p>
					<a href="/artists" class="mt-6 flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-4 py-3 text-sm font-semibold text-primary-fg shadow-sm shadow-primary/20 transition-all hover:bg-primary-hover hover:shadow-md active:scale-95">
						View Library
					</a>
				</div>

				<div class="group relative overflow-hidden rounded-3xl border border-border/60 bg-surface-raised p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-linear-to-br hover:from-surface-raised hover:to-primary/5 hover:shadow-md">
					<div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary transition-transform duration-300 group-hover:scale-110">
						<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="12" cy="12" r="8"></circle>
							<circle cx="12" cy="12" r="2"></circle>
						</svg>
					</div>
					<h3 class="text-xl font-bold tracking-tight text-text group-hover:text-primary">Albums</h3>
					<p class="mt-1 text-sm text-text-muted">Track all of your favorite specific releases.</p>
					<a href="/albums" class="mt-6 flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-4 py-3 text-sm font-semibold text-primary-fg shadow-sm shadow-primary/20 transition-all hover:bg-primary-hover hover:shadow-md active:scale-95">
						View Library
					</a>
				</div>

				<div class="group relative overflow-hidden rounded-3xl border border-border/60 bg-surface-raised p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-linear-to-br hover:from-surface-raised hover:to-primary/5 hover:shadow-md sm:col-span-2 lg:col-span-1">
					<div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-secondary/10 text-secondary transition-transform duration-300 group-hover:scale-110">
						<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 5v14M5 12h14"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold tracking-tight text-text group-hover:text-secondary">Create</h3>
					<p class="mt-1 text-sm text-text-muted">Expand your personalized library database.</p>
					<button id="home-open-create" type="button" class="mt-6 flex w-full cursor-pointer items-center justify-center gap-2 rounded-xl bg-secondary px-4 py-3 text-sm font-semibold text-white shadow-sm shadow-secondary/20 transition-all hover:bg-secondary-hover hover:shadow-md active:scale-95">
						New Entry
					</button>
				</div>
			</div>
</AppPageLayout>

<script>
	document.getElementById('home-open-create')?.addEventListener('click', () => {
		window.dispatchEvent(new CustomEvent('open-create-menu'));
	});
</script>
