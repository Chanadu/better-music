---
import Layout from '../layouts/Layout.astro';

const quickStats = [
	{ label: 'Albums tracked', value: '248', detail: '+12 this month' },
	{ label: 'Artists saved', value: '91', detail: '18 favorites' },
	{ label: 'Listening goals', value: '72%', detail: 'April progress' },
];

const recentAlbums = [
	{
		title: 'Midnight Catalog',
		artist: 'Nova Vale',
		rating: '9.1',
		status: 'Loved',
		cover: 'https://picsum.photos/seed/better-music-album-1/320/320',
	},
	{
		title: 'Glass District',
		artist: 'The Low Signals',
		rating: '8.4',
		status: 'Replay',
		cover: 'https://picsum.photos/seed/better-music-album-2/320/320',
	},
	{
		title: 'Sunday Static',
		artist: 'Elio North',
		rating: '7.8',
		status: 'Review',
		cover: 'https://picsum.photos/seed/better-music-album-3/320/320',
	},
];

const queue = ['Finish rating April discoveries', 'Sync saved Spotify albums', 'Add notes for jazz rotation'];
---

<Layout title='Better Music'>
	<div class='drawer lg:drawer-open'>
		<input id='app-drawer' type='checkbox' class='drawer-toggle' />
		<div class='drawer-content flex min-h-screen flex-col'>
			<header class='navbar sticky top-0 z-20 border-b border-base-300 bg-base-100/95 px-4 backdrop-blur lg:px-8'>
				<div class='flex-none lg:hidden'>
					<label for='app-drawer' aria-label='Open navigation' class='btn btn-square btn-ghost'>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							viewBox='0 0 24 24'
							fill='none'
							stroke='currentColor'
							stroke-width='2'
							class='h-5 w-5'
							aria-hidden='true'
						>
							<path d='M4 6h16M4 12h16M4 18h16'></path>
						</svg>
					</label>
				</div>
				<div class='flex-1'>
					<a class='btn btn-ghost text-lg font-semibold tracking-normal'>Better Music</a>
				</div>
				<div class='hidden flex-none items-center gap-2 md:flex'>
					<label class='input input-bordered input-sm flex w-64 items-center gap-2'>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							viewBox='0 0 24 24'
							fill='none'
							stroke='currentColor'
							stroke-width='2'
							class='h-4 w-4 opacity-60'
							aria-hidden='true'
						>
							<circle cx='11' cy='11' r='7'></circle>
							<path d='m21 21-4.3-4.3'></path>
						</svg>
						<input type='search' class='grow' placeholder='Search library' />
					</label>
					<button class='btn btn-primary btn-sm'>Add album</button>
				</div>
			</header>

			<main class='flex-1 px-4 py-6 lg:px-8'>
				<section class='mx-auto grid max-w-7xl gap-6'>
					<div class='grid gap-4 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-start'>
						<div class='rounded-box bg-base-100 p-6 shadow-sm'>
							<div class='flex flex-col gap-5 md:flex-row md:items-end md:justify-between'>
								<div class='max-w-2xl'>
									<div class='badge badge-primary badge-soft mb-3'>Library dashboard</div>
									<h1 class='text-3xl font-bold tracking-normal md:text-4xl'>Build your listening system.</h1>
									<p class='mt-3 text-base text-base-content/70'>
										Track albums, rate discoveries, and keep the next listen close at hand.
									</p>
								</div>
								<div class='join'>
									<button class='btn join-item btn-primary'>Import</button>
									<button class='btn join-item'>Review</button>
								</div>
							</div>

							<div class='mt-6 grid gap-3 md:grid-cols-3'>
								{
									quickStats.map((stat) => (
										<div class='stat rounded-box border border-base-300 bg-base-200'>
											<div class='stat-title'>{stat.label}</div>
											<div class='stat-value text-2xl'>{stat.value}</div>
											<div class='stat-desc'>{stat.detail}</div>
										</div>
									))
								}
							</div>
						</div>

						<aside class='rounded-box bg-base-100 p-5 shadow-sm'>
							<div class='flex items-center justify-between gap-3'>
								<h2 class='text-lg font-semibold'>Today</h2>
								<div class='badge badge-accent badge-outline'>3 tasks</div>
							</div>
							<ul class='menu mt-3 w-full p-0'>
								{
									queue.map((item) => (
										<li>
											<label class='flex items-start gap-3 rounded-box'>
												<input type='checkbox' class='checkbox checkbox-primary checkbox-sm mt-1' />
												<span>{item}</span>
											</label>
										</li>
									))
								}
							</ul>
							<div class='divider my-4'></div>
							<div class='alert alert-info alert-soft'>
								<span>Spotify sync is ready to connect when the backend endpoint is wired in.</span>
							</div>
						</aside>
					</div>

					<div class='grid gap-6 xl:grid-cols-[minmax(0,1fr)_24rem]'>
						<section class='rounded-box bg-base-100 p-5 shadow-sm'>
							<div class='mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between'>
								<div>
									<h2 class='text-xl font-semibold'>Recent albums</h2>
									<p class='text-sm text-base-content/60'>A starter collection view using DaisyUI cards.</p>
								</div>
								<div role='tablist' class='tabs tabs-box tabs-sm'>
									<a role='tab' class='tab tab-active'>All</a>
									<a role='tab' class='tab'>Loved</a>
									<a role='tab' class='tab'>Queue</a>
								</div>
							</div>

							<div class='grid gap-4 md:grid-cols-3'>
								{
									recentAlbums.map((album) => (
										<article class='card card-border bg-base-100'>
											<figure class='aspect-square overflow-hidden'>
												<img src={album.cover} alt={`${album.title} album cover`} class='h-full w-full object-cover' />
											</figure>
											<div class='card-body gap-3 p-4'>
												<div>
													<h3 class='card-title text-base'>{album.title}</h3>
													<p class='text-sm text-base-content/60'>{album.artist}</p>
												</div>
												<div class='card-actions items-center justify-between'>
													<div class='badge badge-secondary badge-soft'>{album.status}</div>
													<div class='rating rating-sm'>
														<input type='radio' name={`${album.title}-rating`} class='mask mask-star-2 bg-warning' checked />
														<input type='radio' name={`${album.title}-rating`} class='mask mask-star-2 bg-warning' checked />
														<input type='radio' name={`${album.title}-rating`} class='mask mask-star-2 bg-warning' checked />
														<input type='radio' name={`${album.title}-rating`} class='mask mask-star-2 bg-warning' checked />
														<input type='radio' name={`${album.title}-rating`} class='mask mask-star-2 bg-warning' />
													</div>
												</div>
												<div class='text-sm font-medium'>Rating {album.rating}</div>
											</div>
										</article>
									))
								}
							</div>
						</section>

						<section class='rounded-box bg-base-100 p-5 shadow-sm'>
							<div class='flex items-center justify-between'>
								<h2 class='text-xl font-semibold'>Activity</h2>
								<button class='btn btn-ghost btn-sm'>View all</button>
							</div>
							<div class='mt-4 overflow-x-auto'>
								<table class='table table-zebra'>
									<thead>
										<tr>
											<th>Type</th>
											<th>Name</th>
											<th>When</th>
										</tr>
									</thead>
									<tbody>
										<tr>
											<td><span class='badge badge-primary badge-soft'>Album</span></td>
											<td>Midnight Catalog</td>
											<td>Today</td>
										</tr>
										<tr>
											<td><span class='badge badge-success badge-soft'>Artist</span></td>
											<td>Nova Vale</td>
											<td>Yesterday</td>
										</tr>
										<tr>
											<td><span class='badge badge-warning badge-soft'>Note</span></td>
											<td>April discoveries</td>
											<td>Mon</td>
										</tr>
									</tbody>
								</table>
							</div>
						</section>
					</div>
				</section>
			</main>
		</div>

		<aside class='drawer-side z-30'>
			<label for='app-drawer' aria-label='Close navigation' class='drawer-overlay'></label>
			<nav class='min-h-full w-72 border-r border-base-300 bg-base-100 p-4'>
				<div class='mb-6 flex items-center gap-3 px-2'>
					<div class='avatar placeholder'>
						<div class='w-10 rounded-box bg-primary text-primary-content'>
							<span>BM</span>
						</div>
					</div>
					<div>
						<div class='font-semibold'>Better Music</div>
						<div class='text-sm text-base-content/60'>Personal library</div>
					</div>
				</div>
				<ul class='menu w-full gap-1 p-0'>
					<li><a class='active'>Dashboard</a></li>
					<li><a>Albums</a></li>
					<li><a>Artists</a></li>
					<li><a>Listened</a></li>
					<li><a>Settings</a></li>
				</ul>
			</nav>
		</aside>
	</div>
</Layout>
