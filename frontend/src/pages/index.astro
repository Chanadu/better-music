---
import AppHeader from '../components/ui/AppHeader.astro';
import AuthGuard from '../components/auth/AuthGuard.astro';
import BottomTabBar from '../components/ui/BottomTabBar.astro';
import CreateMenuModal from '../components/create/CreateMenuModal.astro';
import SectionPanel from '../components/ui/SectionPanel.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<AuthGuard />
	<AppHeader title="Your Library" />
	<main class="min-h-screen bg-gradient-to-br from-bg to-surface-raised px-4 pt-6 pb-28 sm:px-6 sm:pt-8 md:px-8">
		<!-- Main Content Wrapper -->
		<div class="mx-auto max-w-4xl">

			<!-- Welcome Stats / Hero area (placeholder for future stats) -->
			<div class="mb-8 overflow-hidden rounded-3xl bg-gradient-to-tr from-primary to-primary-hover p-6 text-white shadow-xl dark:shadow-primary/20">
				<h2 class="text-2xl font-bold tracking-tight">Welcome back</h2>
				<p class="mt-2 text-primary-fg/80">Ready to discover more music?</p>
			</div>

			<!-- Home Content Actions -->
			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 sm:gap-6">
				<!-- Artists Card -->
				<SectionPanel title="Artists" description="Browse and manage your music collection">
					<a href="/artists" class="mt-2 inline-flex w-full items-center justify-center rounded-xl bg-primary px-4 py-3 text-sm font-semibold text-primary-fg shadow-sm transition-all duration-300 hover:bg-primary-hover hover:shadow active:scale-95 sm:w-auto">
						View Artists
					</a>
				</SectionPanel>

				<!-- Albums Card -->
				<SectionPanel title="Albums" description="Explore albums by your favorite artists">
					<a href="/albums" class="mt-2 inline-flex w-full items-center justify-center rounded-xl bg-primary px-4 py-3 text-sm font-semibold text-primary-fg shadow-sm transition-all duration-300 hover:bg-primary-hover hover:shadow active:scale-95 sm:w-auto">
						View Albums
					</a>
				</SectionPanel>

				<!-- Create Card -->
				<SectionPanel title="Create" description="Add a new artist or album to your library">
					<button id="home-open-create" type="button" class="mt-2 inline-flex w-full cursor-pointer items-center justify-center rounded-xl bg-primary px-4 py-3 text-sm font-semibold text-primary-fg shadow-sm transition-all duration-300 hover:bg-primary-hover hover:shadow active:scale-95 sm:w-auto">
						New Entry
					</button>
				</SectionPanel>
			</div>
		</div>
	</main>
	<CreateMenuModal />
	<BottomTabBar current="home" />
</Layout>

<script>
	document.getElementById('home-open-create')?.addEventListener('click', () => {
		window.dispatchEvent(new CustomEvent('open-create-menu'));
	});
</script>
