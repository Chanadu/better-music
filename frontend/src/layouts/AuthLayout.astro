---
import BaseLayout from './BaseLayout.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<BaseLayout>
	<div class='hero min-h-screen'>
		<div class='hero-content w-full max-w-lg flex-col lg:flex-row-reverse'>
			<div class='text-center lg:text-left'>
				<h1 class='text-2xl font-semibold'>{title}</h1>
			</div>
			<div class='card bg-base-200 w-full'>
				<div class='card-body'>
					<slot />
				</div>
			</div>
		</div>
	</div>

	<script>
		import { saveTokens, type TokenResponse } from '../scripts/auth';

		const authForms = document.querySelectorAll<HTMLFormElement>('form[data-auth-form]');

		const showFormError = (form: HTMLFormElement, message: string) => {
			const errorElement = form.querySelector<HTMLElement>('[data-auth-error]');

			if (!errorElement) return;

			errorElement.textContent = message;
			errorElement.classList.remove('hidden');
		};

		const clearFormError = (form: HTMLFormElement) => {
			const errorElement = form.querySelector<HTMLElement>('[data-auth-error]');

			if (!errorElement) return;

			errorElement.textContent = '';
			errorElement.classList.add('hidden');
		};

		authForms.forEach((form) => {
			const fieldset = form.querySelector<HTMLFieldSetElement>('.fieldset');

			if (!fieldset) return;

			const requiredInputs: HTMLInputElement[] = Array.from(fieldset.querySelectorAll('input[required]'));
			const submitButton = fieldset.querySelector<HTMLButtonElement>('button[type="submit"]');
			const loadingIndicator = fieldset.querySelector<HTMLElement>('[data-auth-loading]');

			if (!submitButton) return;

			const updateButtonState = () => {
				requiredInputs.forEach((input) => {
					const matchTarget = input.dataset.match;

					if (!matchTarget) return;

					const targetInput: HTMLInputElement | null = fieldset.querySelector(`input[name="${matchTarget}"]`);
					const matchesTarget = targetInput && input.value === targetInput.value;

					input.setCustomValidity(matchesTarget ? '' : 'Passwords must match');
				});

				const isDisabled = !requiredInputs.every((input) => input.checkValidity());

				submitButton.disabled = isDisabled;
				submitButton.classList.toggle('btn-disabled', isDisabled);
			};

			requiredInputs.forEach((input) => {
				input.addEventListener('input', updateButtonState);
			});

			form.addEventListener('submit', async (event) => {
				event.preventDefault();

				if (!form.checkValidity()) {
					form.reportValidity();
					return;
				}

				const endpoint = form.dataset.authEndpoint;

				if (!endpoint) return;

				const formData = new FormData(form);
				const email = String(formData.get('email') ?? '');
				const password = String(formData.get('password') ?? '');

				clearFormError(form);
				submitButton.disabled = true;
				submitButton.classList.add('btn-disabled');
				loadingIndicator?.classList.remove('hidden');
				loadingIndicator?.classList.add('flex');

				try {
					const response = await fetch(endpoint, {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
						},
						body: JSON.stringify({ email, password }),
					});

					const responseBody = await response.json().catch(() => null);

					if (!response.ok) {
						const message =
							responseBody && typeof responseBody.error === 'string' ?
								responseBody.error
							:	'Authentication failed. Please try again.';

						showFormError(form, message);
						return;
					}

					saveTokens(responseBody as TokenResponse);
					window.location.assign(form.dataset.successPath ?? '/');
				} catch {
					showFormError(form, 'Could not reach the server. Please try again.');
				} finally {
					loadingIndicator?.classList.add('hidden');
					loadingIndicator?.classList.remove('flex');
					updateButtonState();
				}
			});

			updateButtonState();
		});
	</script>
</BaseLayout>
