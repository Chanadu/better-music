---
import BaseLayout from './BaseLayout.astro';
import BottomNav from '../components/nav/BottomNav.astro';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<BaseLayout>
	<main class='p-6 pb-[calc(6rem+env(safe-area-inset-bottom))]'>
		<slot />
	</main>

	<BottomNav currentPath={pathname} />
</BaseLayout>

<script>
	import { getValidAccessToken, redirectToLogin } from '../scripts/auth';
	import { fetchDatabaseData, refreshStaleDatabaseData } from '../scripts/database';

	const refreshStaleData = () => {
		refreshStaleDatabaseData().catch((error) => {
			console.error('Failed to refresh database data', error);
		});
	};

	const accessToken = await getValidAccessToken();

	if (!accessToken) {
		redirectToLogin();
	} else {
		fetchDatabaseData().catch((error) => {
			console.error('Failed to load database data', error);
		});

		refreshStaleData();

		document.addEventListener('visibilitychange', () => {
			if (document.visibilityState === 'visible') {
				refreshStaleData();
			}
		});

		window.addEventListener('focus', refreshStaleData);
	}
</script>
