---
import BaseLayout from './BaseLayout.astro';
import BottomNav from '../components/nav/BottomNav.astro';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<BaseLayout>
	<main class='p-6 pb-[calc(6rem+env(safe-area-inset-bottom))]'>
		<slot />
	</main>

	<BottomNav currentPath={pathname} />
</BaseLayout>

<script>
	import { getValidAccessToken, redirectToLogin } from '../scripts/auth';
	import { fetchDatabaseData } from '../scripts/database';

	const accessToken = await getValidAccessToken();

	if (!accessToken) {
		redirectToLogin();
	} else {
		fetchDatabaseData().catch((error) => {
			console.error('Failed to load database data', error);
		});
	}
</script>
