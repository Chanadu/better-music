---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
---

<!doctype html>
<html lang='en' class='m-0 min-h-screen w-full overscroll-y-none bg-surface-raised'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover' />
		<ClientRouter />
		<meta id='theme-color-meta' name='theme-color' content='#f6f7fb' />
		<!-- <link rel='icon' type='image/svg+xml' href='/favicon.svg' /> -->
		<!-- <link rel='icon' href='/favicon.ico' /> -->
		<meta name='generator' content={Astro.generator} />
		<title>Better-Music</title>
		<style is:inline>
			::view-transition-old(root),
			::view-transition-new(root) {
				animation-duration: 20ms;
				animation-timing-function: ease-out;
			}

			::view-transition-old(root) {
				animation-name: fade-out;
			}

			::view-transition-new(root) {
				animation-name: fade-in;
			}

			@keyframes fade-out {
				from { opacity: 1; }
				to { opacity: 0.94; }
			}

			@keyframes fade-in {
				from { opacity: 0.94; }
				to { opacity: 1; }
			}
		</style>
		<!-- Apply saved or system-preferred theme before first paint to avoid flash -->
		<script is:inline>
			(function () {
				const themeMeta = document.getElementById('theme-color-meta');
				const setThemeColor = (isDark) => {
					themeMeta.setAttribute('content', isDark ? '#0f172a' : '#f6f7fb');
				};

				const syncSavedTheme = () => {
					const saved = localStorage.getItem('theme');
					const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
					const useDark = saved === 'dark' || (!saved && prefersDark);
					document.documentElement.classList.toggle('dark', useDark);
					setThemeColor(useDark);
				};

				syncSavedTheme();
				document.addEventListener('astro:after-swap', syncSavedTheme);
				document.addEventListener('astro:page-load', syncSavedTheme);
			})();
		</script>
	</head>
	<body class='m-0 min-h-screen w-full overscroll-y-none'>
		<slot />
		<script>
			// Exposed for pages that need to trigger a theme toggle programmatically.
			declare global {
				interface Window {
					toggleTheme: () => void;
					__routePreloadBound?: boolean;
					__preloadedRoutes?: Record<string, boolean>;
					__linkPrefetchBound?: boolean;
				}
			}
			window.toggleTheme = (): void => {
				const isDark = document.documentElement.classList.toggle('dark');
				localStorage.setItem('theme', isDark ? 'dark' : 'light');
				const themeMeta = document.getElementById('theme-color-meta');
				if (themeMeta) {
					themeMeta.setAttribute('content', isDark ? '#0f172a' : '#f6f7fb');
				}
			};

			const preloadRoutes = (): void => {
				const routes = ['/', '/albums', '/listened', '/artists', '/login', '/register', '/offline'];
				const currentPath = window.location.pathname;
				const preloadState = (window.__preloadedRoutes ??= {});

				for (const route of routes) {
					if (route === currentPath || preloadState[route]) continue;
					preloadState[route] = true;
					void fetch(route, {
						method: 'GET',
						credentials: 'same-origin',
						headers: { 'x-preload': '1' },
					}).catch(() => {
						preloadState[route] = false;
					});
				}
			};

			if (!window.__routePreloadBound) {
				window.__routePreloadBound = true;
				const kickOffPreload = () => {
					if ('requestIdleCallback' in window) {
						(window as Window & { requestIdleCallback: (cb: () => void) => number }).requestIdleCallback(() => preloadRoutes());
					} else {
						setTimeout(() => preloadRoutes(), 0);
					}
				};
				document.addEventListener('astro:page-load', kickOffPreload);
				kickOffPreload();
			}

			const prefetchRoute = (route: string): void => {
				if (!route || route.startsWith('http') || route.startsWith('mailto:') || route.startsWith('tel:')) return;
				const cleanRoute = route.split('#')[0].split('?')[0] || route;
				const preloadState = (window.__preloadedRoutes ??= {});
				if (cleanRoute === window.location.pathname || preloadState[cleanRoute]) return;
				preloadState[cleanRoute] = true;
				void fetch(cleanRoute, {
					method: 'GET',
					credentials: 'same-origin',
					headers: { 'x-preload': '1' },
				}).catch(() => {
					preloadState[cleanRoute] = false;
				});
			};

			if (!window.__linkPrefetchBound) {
				window.__linkPrefetchBound = true;
				const handleLinkHint = (event: Event) => {
					const target = event.target as Element | null;
					const link = target?.closest('a[href]') as HTMLAnchorElement | null;
					if (!link) return;
					prefetchRoute(link.getAttribute('href') ?? '');
				};

				document.addEventListener('pointerenter', handleLinkHint, { capture: true });
				document.addEventListener('touchstart', handleLinkHint, { capture: true, passive: true });
				document.addEventListener('focusin', handleLinkHint, { capture: true });
			}
		</script>
	</body>
</html>
