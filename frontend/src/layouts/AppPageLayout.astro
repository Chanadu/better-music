---
import AuthGuard from '../components/auth/AuthGuard.astro';
import CreateMenuModal from '../components/create/CreateMenuModal.astro';
import AppHeader from '../components/ui/AppHeader.astro';
import BottomTabBar from '../components/ui/BottomTabBar.astro';
import Layout from './Layout.astro';

interface Props {
	title: string;
	current: 'unlistened' | 'listened' | 'artists';
	maxWidthClass?: string;
	mainClassName?: string;
	containerClassName?: string;
}

const {
	title,
	current,
	maxWidthClass = 'max-w-4xl',
	mainClassName = 'min-h-screen px-4 pt-6 pb-32 sm:px-6 sm:pt-8 sm:pb-36 md:px-8',
	containerClassName = 'space-y-6 sm:space-y-7',
} = Astro.props as Props;
---

<Layout>
	<AuthGuard />
	<AppHeader title={title} />
	<main class={mainClassName}>
		<div class={`mx-auto ${maxWidthClass} ${containerClassName}`}>
			<slot />
		</div>
	</main>

	<CreateMenuModal />
	<BottomTabBar current={current} />
</Layout>
